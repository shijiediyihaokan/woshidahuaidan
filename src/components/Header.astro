---
import { categoryTree } from '../data/categories';
---

<!-- Top Bar -->
<div class="bg-dark-800 text-steel-300 text-xs">
  <div class="container-page">
    <div class="flex items-center justify-between h-9">
      <div class="flex items-center gap-3">
        <span>📞 +86-18057543143</span>
        <a href="mailto:info@ggn-gear.com" class="hover:text-white transition-colors">✉ info@ggn-gear.com</a>
      </div>
      <div class="flex items-center gap-3">
        <form action="/woshidahuaidan/search/" class="hidden sm:flex items-center">
          <input type="text" name="q" placeholder="Search..." class="w-32 lg:w-40 bg-dark-700 text-white text-xs px-2 py-1 rounded border-0 focus:outline-none focus:ring-1 focus:ring-brand-500">
          <button type="submit" class="text-steel-400 hover:text-white ml-1">🔍</button>
        </form>
        <button class="hover:text-white">🌐 EN</button>
        <a href="/woshidahuaidan/contact/" class="bg-brand-600 hover:bg-brand-700 text-white px-3 py-1 rounded text-xs font-semibold transition-colors">Contact Now！</a>
      </div>
    </div>
  </div>
</div>

<!-- Main Navigation -->
<header class="sticky top-0 z-50 bg-white border-b border-steel-200 shadow-sm">
  <div class="container-page">
    <div class="flex items-center justify-between h-16">
      <a href="/woshidahuaidan/" class="flex items-center gap-2 shrink-0">
        <span class="text-2xl font-black text-brand-600 tracking-tight">GRANGIN</span>
      </a>

      <nav class="hidden lg:flex items-center gap-0 h-full">
        <a href="/woshidahuaidan/" class="px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 h-full flex items-center">Home</a>

        <!-- Products dropdown -->
        <div class="relative group h-full flex items-center">
          <a href="/woshidahuaidan/products/" class="flex items-center gap-1 px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 h-full">Products ▾</a>
          <div class="absolute top-full left-0 mt-0 w-64 bg-white border border-steel-200 rounded-b-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 max-h-[80vh] overflow-y-auto">
            {categoryTree.map((cat) => (
              <div>
                <a href={`/woshidahuaidan/products/?category=${cat.slug}`} class="block px-4 py-2.5 text-sm font-bold text-steel-800 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100 flex items-center gap-2">
                  <span>{cat.icon}</span> {cat.name}
                </a>
                {cat.subcategories.map((sc) => (
                  <a href={`/woshidahuaidan/products/?category=${cat.slug}&sub=${sc.slug}`} class="block pl-10 pr-4 py-2 text-sm text-steel-500 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-50">
                    {sc.name}
                  </a>
                ))}
              </div>
            ))}
          </div>
        </div>

        <a href="/woshidahuaidan/applications/" class="px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 h-full flex items-center">Applications</a>

        <!-- Custom Manufacturing dropdown -->
        <div class="relative group h-full flex items-center">
          <a href="/woshidahuaidan/custom-manufacturing/" class="flex items-center gap-1 px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 h-full">Custom Manufacturing ▾</a>
          <div class="absolute top-full left-0 mt-0 w-52 bg-white border border-steel-200 rounded-b-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <a href="/woshidahuaidan/custom-manufacturing/cnc-machining/" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">CNC Machining</a>
            <a href="/woshidahuaidan/custom-manufacturing/laser-cutting/" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Laser Cutting</a>
            <a href="/woshidahuaidan/custom-manufacturing/sheet-metal-bending/" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Sheet Metal Bending</a>
            <a href="/woshidahuaidan/custom-manufacturing/welding-fabrication/" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Welding Fabrication</a>
            <a href="/woshidahuaidan/custom-manufacturing/heat-treatment/" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Heat Treatment</a>
            <a href="/woshidahuaidan/custom-manufacturing/surface-treatment/" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Surface Treatment</a>
            <a href="/woshidahuaidan/custom-manufacturing/materials/" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600">Materials</a>
          </div>
        </div>
        <a href="/woshidahuaidan/knowledge-center/" class="px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 h-full flex items-center">Knowledge Center</a>
        <a href="/woshidahuaidan/about/" class="px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 h-full flex items-center">About Us</a>
        <a href="/woshidahuaidan/contact/" class="px-3 py-2 text-sm font-semibold text-brand-600 hover:text-brand-700 h-full flex items-center">Contact</a>
      </nav>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-lg text-steel-600 hover:bg-steel-100" aria-label="Toggle menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          <path id="menu-icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4 border-t border-steel-100 mt-2 pt-2">
      <a href="/woshidahuaidan/" class="block px-4 py-3 text-sm font-semibold text-steel-700 border-b border-steel-50">Home</a>
      <a href="/woshidahuaidan/products/" class="block px-4 py-3 text-sm font-semibold text-steel-700 border-b border-steel-50">Products</a>
      <a href="/woshidahuaidan/applications/" class="block px-4 py-3 text-sm font-semibold text-steel-700 border-b border-steel-50">Applications</a>
      <a href="/woshidahuaidan/custom-manufacturing/" class="block px-4 py-3 text-sm font-semibold text-steel-700 border-b border-steel-50">Custom Manufacturing</a>
      <a href="/woshidahuaidan/knowledge-center/" class="block px-4 py-3 text-sm font-semibold text-steel-700 border-b border-steel-50">Knowledge Center</a>
      <a href="/woshidahuaidan/about/" class="block px-4 py-3 text-sm font-semibold text-steel-700 border-b border-steel-50">About Us</a>
      <a href="/woshidahuaidan/contact/" class="block px-4 py-3 text-sm font-semibold text-brand-600">Contact</a>
    </div>
  </div>
</header>

<script>
  const btn=document.getElementById('mobile-menu-btn'),menu=document.getElementById('mobile-menu'),o=document.getElementById('menu-icon-open'),c=document.getElementById('menu-icon-close');
  btn?.addEventListener('click',()=>{menu?.classList.toggle('hidden');o?.classList.toggle('hidden');c?.classList.toggle('hidden')});
</script>
