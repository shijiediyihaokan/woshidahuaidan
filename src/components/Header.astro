<!-- Top Bar -->
<div class="bg-dark-800 text-steel-300 text-xs">
  <div class="container-page">
    <div class="flex items-center justify-between h-9">
      <div class="flex items-center gap-3">
        <span>📞 +86-18057543143</span>
        <a href="mailto:info@ggn-gear.com" class="hover:text-white transition-colors">✉ info@ggn-gear.com</a>
      </div>
      <div class="flex items-center gap-3">
        <form action="/woshidahuaidan/search/" class="hidden sm:flex items-center">
          <input type="text" name="q" placeholder="Search products..." class="w-32 lg:w-40 bg-dark-700 text-white text-xs px-2 py-1 rounded border-0 focus:outline-none focus:ring-1 focus:ring-brand-500">
          <button type="submit" class="text-steel-400 hover:text-white ml-1">🔍</button>
        </form>
