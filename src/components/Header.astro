---
// ============================================================
// Header.astro — CTS-style header with top bar + main nav
// ============================================================
---

<!-- Top Bar -->
<div class="bg-dark-800 text-steel-300 text-xs">
  <div class="container-page">
    <div class="flex items-center justify-between h-9">
      <div class="flex items-center gap-4">
        <a href="/about/" class="hover:text-white transition-colors">Customized Service</a>
        <a href="/blog/" class="hover:text-white transition-colors">Blog</a>
        <a href="/faq/" class="hover:text-white transition-colors">FAQ</a>
        <div class="relative group">
          <button class="hover:text-white transition-colors flex items-center gap-1">
            🌐 English ▾
          </button>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <form action="/search/" class="hidden sm:flex items-center">
          <input type="text" name="q" placeholder="Search products..." 
            class="w-32 lg:w-40 bg-dark-700 text-white text-xs px-2 py-1 rounded border-0 focus:outline-none focus:ring-1 focus:ring-brand-500">
          <button type="submit" class="text-steel-400 hover:text-white ml-1">🔍</button>
        </form>
        <a href="/contact/" class="bg-brand-600 hover:bg-brand-700 text-white px-3 py-1 rounded text-xs font-semibold transition-colors">
          Contact Now！
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Main Navigation -->
<header class="sticky top-0 z-50 bg-white border-b border-steel-200 shadow-sm">
  <div class="container-page">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/woshidahuaidan/" class="flex items-center gap-2 shrink-0">
        <span class="text-2xl font-black text-brand-600 tracking-tight">GUANGJIN</span>
        <span class="hidden lg:inline text-xs text-steel-500 font-medium leading-tight max-w-[100px]">Industrial<br>Transmission</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-0 h-full">
        <!-- Gearboxes -->
        <div class="relative group h-full flex items-center">
          <a href="/products/?category=gearbox" class="flex items-center gap-1 px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 transition-colors h-full">
            GEARBOXES ▾
          </a>
          <div class="absolute top-full left-0 mt-0 w-56 bg-white border border-steel-200 rounded-b-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <a href="/products/?category=worm-gearbox" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Worm Gearbox</a>
            <a href="/products/?category=helical-gearbox" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Helical Gearbox</a>
            <a href="/products/?category=bevel-gearbox" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Bevel Gearbox</a>
            <a href="/products/?category=industrial-gearbox" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600">Industrial Gearbox</a>
          </div>
        </div>

        <!-- Gear Motors -->
        <div class="relative group h-full flex items-center">
          <a href="/products/?category=gear-motor" class="flex items-center gap-1 px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 transition-colors h-full">
            GEAR MOTORS ▾
          </a>
          <div class="absolute top-full left-0 mt-0 w-48 bg-white border border-steel-200 rounded-b-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <a href="/products/?category=gear-motor" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">GM Series Gear Motor</a>
            <a href="/products/?category=ac-motor" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600">AC Motor</a>
          </div>
        </div>

        <!-- Power Transmission -->
        <div class="relative group h-full flex items-center">
          <a href="/products/?category=power-transmission" class="flex items-center gap-1 px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 transition-colors h-full">
            POWER TRANSMISSION ▾
          </a>
          <div class="absolute top-full left-0 mt-0 w-48 bg-white border border-steel-200 rounded-b-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <a href="/products/?category=gear" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Gears & Racks</a>
            <a href="/products/?category=sprocket" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Sprockets</a>
            <a href="/products/?category=belt-pulley" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Belt Pulleys</a>
            <a href="/products/?category=coupling" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600">Couplings</a>
          </div>
        </div>

        <a href="/applications/" class="px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 transition-colors h-full flex items-center">
          APPLICATION
        </a>

        <div class="relative group h-full flex items-center">
          <a href="/about/" class="flex items-center gap-1 px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 transition-colors h-full">
            ABOUT ▾
          </a>
          <div class="absolute top-full left-0 mt-0 w-40 bg-white border border-steel-200 rounded-b-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <a href="/about/" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">About Guangjin</a>
            <a href="/about/#factory" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600">Factory Tour</a>
          </div>
        </div>

        <a href="/blog/" class="px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 transition-colors h-full flex items-center">
          GUIDE
        </a>

        <a href="/contact/" class="px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 transition-colors h-full flex items-center">
          CONTACT
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-lg text-steel-600 hover:bg-steel-100" aria-label="Toggle menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path id="menu-icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4 border-t border-steel-100 mt-2 pt-2">
      <a href="/products/" class="block px-4 py-3 text-sm font-semibold text-steel-700 hover:text-brand-600 border-b border-steel-50">GEARBOXES</a>
      <a href="/products/?category=gear-motor" class="block px-4 py-3 text-sm font-semibold text-steel-700 hover:text-brand-600 border-b border-steel-50">GEAR MOTORS</a>
      <a href="/products/?category=power-transmission" class="block px-4 py-3 text-sm font-semibold text-steel-700 hover:text-brand-600 border-b border-steel-50">POWER TRANSMISSION</a>
      <a href="/applications/" class="block px-4 py-3 text-sm font-semibold text-steel-700 hover:text-brand-600 border-b border-steel-50">APPLICATION</a>
      <a href="/about/" class="block px-4 py-3 text-sm font-semibold text-steel-700 hover:text-brand-600 border-b border-steel-50">ABOUT</a>
      <a href="/blog/" class="block px-4 py-3 text-sm font-semibold text-steel-700 hover:text-brand-600 border-b border-steel-50">GUIDE</a>
      <a href="/contact/" class="block px-4 py-3 text-sm font-semibold text-steel-700 hover:text-brand-600">CONTACT</a>
      <a href="/contact/" class="block mt-3 mx-4 py-3 bg-brand-600 text-white text-sm font-bold rounded text-center hover:bg-brand-700 transition-colors">
        Contact Now！
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
