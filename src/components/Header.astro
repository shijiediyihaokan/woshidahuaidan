---
// ============================================================
// Header.astro — CTS-style header with Guangjin product lines
// ============================================================
---

<!-- Top Bar -->
<div class="bg-dark-800 text-steel-300 text-xs">
  <div class="container-page">
    <div class="flex items-center justify-between h-9">
      <div class="flex items-center gap-3">
        <span>📞 +86-18057543143</span>
        <a href="mailto:info@ggn-gear.com" class="hover:text-white transition-colors">✉ info@ggn-gear.com</a>
      </div>
      <div class="flex items-center gap-3">
        <form action="/woshidahuaidan/search/" class="hidden sm:flex items-center">
          <input type="text" name="q" placeholder="Search products..." 
            class="w-32 lg:w-40 bg-dark-700 text-white text-xs px-2 py-1 rounded border-0 focus:outline-none focus:ring-1 focus:ring-brand-500">
          <button type="submit" class="text-steel-400 hover:text-white ml-1">🔍</button>
        </form>
        <div class="relative group">
          <button class="hover:text-white transition-colors flex items-center gap-1">🌐 English ▾</button>
        </div>
        <a href="/woshidahuaidan/contact/" class="bg-brand-600 hover:bg-brand-700 text-white px-3 py-1 rounded text-xs font-semibold transition-colors">
          Contact Now！
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Main Navigation -->
<header class="sticky top-0 z-50 bg-white border-b border-steel-200 shadow-sm">
  <div class="container-page">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/woshidahuaidan/" class="flex items-center gap-2 shrink-0">
        <span class="text-2xl font-black text-brand-600 tracking-tight">GRANGIN</span>
        <span class="hidden lg:inline text-xs text-steel-500 font-medium leading-tight max-w-[100px]">Power<br>Transmission</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-0 h-full">
        <a href="/woshidahuaidan/" class="px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 transition-colors h-full flex items-center">
          HOME
        </a>

        <!-- Products -->
        <div class="relative group h-full flex items-center">
          <a href="/woshidahuaidan/products/" class="flex items-center gap-1 px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 transition-colors h-full">
            PRODUCTS ▾
          </a>
          <div class="absolute top-full left-0 mt-0 w-52 bg-white border border-steel-200 rounded-b-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <a href="/woshidahuaidan/products/?category=gears-racks" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Gears & Racks</a>
            <a href="/woshidahuaidan/products/?category=spur-gear" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Spur Gear</a>
            <a href="/woshidahuaidan/products/?category=helical-gear" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Helical Gear</a>
            <a href="/woshidahuaidan/products/?category=sprockets-chains" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Sprockets & Chains</a>
            <a href="/woshidahuaidan/products/?category=spiral-bevel-gear" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Spiral Bevel Gear</a>
            <a href="/woshidahuaidan/products/?category=bevel-gear" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Bevel Gear</a>
            <a href="/woshidahuaidan/products/?category=worm-gears" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Worm Gears</a>
            <a href="/woshidahuaidan/products/?category=couplings" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Couplings</a>
            <a href="/woshidahuaidan/products/?category=gear-shaft" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Gear Shaft</a>
            <a href="/woshidahuaidan/products/?category=lead-screw" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Lead Screw</a>
            <a href="/woshidahuaidan/products/?category=custom-cnc-parts" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600 border-b border-steel-100">Custom CNC Parts</a>
            <a href="/woshidahuaidan/products/?category=sheet-metal-parts" class="block px-4 py-2.5 text-sm text-steel-600 hover:bg-brand-50 hover:text-brand-600">Sheet Metal Parts</a>
          </div>
        </div>

        <a href="/woshidahuaidan/about/" class="px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 transition-colors h-full flex items-center">
          ABOUT
        </a>

        <a href="/woshidahuaidan/applications/" class="px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 transition-colors h-full flex items-center">
          CUSTOMIZED SERVICE
        </a>

        <a href="/woshidahuaidan/news/" class="px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 transition-colors h-full flex items-center">
          NEWS
        </a>

        <a href="/woshidahuaidan/contact/" class="px-3 py-2 text-sm font-semibold text-steel-700 hover:text-brand-600 transition-colors h-full flex items-center">
          CONTACT
        </a>

        <a href="/woshidahuaidan/download/" class="px-3 py-2 text-sm font-semibold text-brand-600 hover:text-brand-700 transition-colors h-full flex items-center">
          DOWNLOAD
        </a>
      </nav>

      <!-- Mobile -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-lg text-steel-600 hover:bg-steel-100" aria-label="Toggle menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path id="menu-icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden lg:hidden pb-4 border-t border-steel-100 mt-2 pt-2">
      <a href="/woshidahuaidan/" class="block px-4 py-3 text-sm font-semibold text-steel-700 border-b border-steel-50">HOME</a>
      <a href="/woshidahuaidan/products/" class="block px-4 py-3 text-sm font-semibold text-steel-700 border-b border-steel-50">PRODUCTS</a>
      <a href="/woshidahuaidan/about/" class="block px-4 py-3 text-sm font-semibold text-steel-700 border-b border-steel-50">ABOUT</a>
      <a href="/woshidahuaidan/contact/" class="block px-4 py-3 text-sm font-semibold text-steel-700">CONTACT</a>
      <a href="/woshidahuaidan/contact/" class="block mt-3 mx-4 py-3 bg-brand-600 text-white text-sm font-bold rounded text-center hover:bg-brand-700 transition-colors">
        Contact Now！
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
