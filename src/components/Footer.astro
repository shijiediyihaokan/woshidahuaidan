---
import { categoryTree } from '../data/categories';
---

<footer class="bg-dark-900 text-steel-300">
  <div class="container-page py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <div>
        <h3 class="text-white font-bold text-lg mb-4">GRANGIN</h3>
        <p class="text-sm leading-relaxed mb-4 text-steel-400">20+ years focus on transmission industry. National High-Tech Enterprise. ISO 9001/45001/14001 certified.</p>
        <p class="text-sm text-steel-500">No. 862, Sanjie High-tech Park, Shengzhou, Zhejiang, China</p>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Products</h4>
        <ul class="space-y-2.5 text-sm">
          {categoryTree.slice(0, 4).map((cat) => (
            <li><a href={`/woshidahuaidan/products/?category=${cat.slug}`} class="text-steel-400 hover:text-brand-400 transition-colors">{cat.name}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">More</h4>
        <ul class="space-y-2.5 text-sm">
          {categoryTree.slice(4).map((cat) => (
            <li><a href={`/woshidahuaidan/products/?category=${cat.slug}`} class="text-steel-400 hover:text-brand-400 transition-colors">{cat.name}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Contact</h4>
        <ul class="space-y-3 text-sm">
          <li><span class="text-steel-400">📍 No. 862, Sanjie High-tech Park, Shengzhou, Zhejiang</span></li>
          <li><a href="mailto:info@ggn-gear.com" class="text-steel-400 hover:text-brand-400">📧 info@ggn-gear.com</a></li>
          <li><span class="text-steel-400">📞 +86-18057543143</span></li>
        </ul>
      </div>
    </div>
  </div>
  <div class="border-t border-dark-700">
    <div class="container-page py-4 text-xs text-steel-500 text-center">
      &copy; {new Date().getFullYear()} Zhejiang Guangjin Intelligent Technology Co., Ltd.
    </div>
  </div>
</footer>
