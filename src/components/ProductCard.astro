---
import type { CollectionEntry } from 'astro:content';

interface Props {
  product: CollectionEntry<'products'>;
}

const { product } = Astro.props;
const { title, image, excerpt, category } = product.data;
const href = `/products/${product.id}/`;
---

<a href={href} class="group block bg-white rounded-xl border border-steel-200 overflow-hidden hover:shadow-lg hover:border-brand-200 transition-all duration-300">
  <!-- Image -->
  <div class="aspect-[4/3] bg-steel-100 overflow-hidden">
    {image ? (
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-steel-400">
        <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
    )}
  </div>

  <!-- Info -->
  <div class="p-4">
    <span class="text-xs font-semibold text-brand-600 uppercase tracking-wide">{category}</span>
    <h3 class="mt-1 text-base font-semibold text-steel-900 group-hover:text-brand-600 transition-colors line-clamp-2">{title}</h3>
    <p class="mt-2 text-sm text-steel-500 line-clamp-2">{excerpt}</p>
  </div>
</a>
