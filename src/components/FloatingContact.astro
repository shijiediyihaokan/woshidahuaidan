    <span>WeChat</span>
  </button>
</div>

<!-- Mobile FAB -->
<button id="fcFab" class="fc-fab hidden" onclick="toggleFloatingContact()" title="Contact Us">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
</button>

<!-- WeChat QR Modal -->
<div id="wcModal" class="hidden fixed inset-0 bg-black/60 z-[60] flex items-center justify-center p-4" onclick="this.classList.add('hidden')">
  <div class="bg-white rounded-xl p-5 max-w-[260px] w-full text-center shadow-xl" onclick="event.stopPropagation()">
    <h4 class="font-bold text-base mb-2">GRANGIN | Ceten</h4>
    <img src="/images/wechat-qr.jpg" alt="WeChat QR Code" class="w-full rounded-lg mb-2">
    <p class="text-xs text-steel-400">Scan to add on WeChat</p>
    <button onclick="document.getElementById('wcModal').classList.add('hidden')" class="mt-3 text-xs text-steel-400 hover:text-steel-600 underline">Close</button>
  </div>
</div>

<style>
  .floating-contact {
    position: fixed;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 40;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 4px 24px rgba(0,0,0,.08), 0 1px 3px rgba(0,0,0,.04);
    padding: 12px 10px 10px;
    width: 160px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    border: 1px solid #e5e7eb;
  }
  .fc-label {
    font-size: 11px;
    font-weight: 600;
    color: #6b7280;
    text-align: center;
    letter-spacing: .5px;
    margin-bottom: 2px;
  }
  .fc-close {
    position: absolute;
    top: 4px;
    right: 8px;
    background: none;
    border: none;
    font-size: 16px;
    color: #9ca3af;
    cursor: pointer;
    padding: 0 2px;
    line-height: 1;
    transition: color .15s;
  }
  .fc-close:hover { color: #374151; }
  .fc-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    text-decoration: none;
    transition: all .15s;
    border: none;
    cursor: pointer;
    width: 100%;
    text-align: left;
    color: #fff;
  }
  .fc-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(0,0,0,.12); }
  .fc-email { background: #374151; }
  .fc-email:hover { background: #1f2937; }
  .fc-wa { background: #25D366; }
  .fc-wa:hover { background: #1ebe57; }
  .fc-wc { background: #07C160; }
  .fc-wc:hover { background: #06ad56; }
  .fc-btn svg { flex-shrink: 0; }

  /* FAB for mobile */
  .fc-fab {
    position: fixed;
    right: 16px;
    bottom: 80px;
    z-index: 40;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #374151;
    color: #fff;
    border: none;
    box-shadow: 0 4px 16px rgba(0,0,0,.15);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all .15s;
  }
  .fc-fab:hover { transform: scale(1.05); box-shadow: 0 6px 20px rgba(0,0,0,.2); }

  @media (max-width: 1024px) {
    .floating-contact { display: none !important; }
    .fc-fab.hidden { display: none !important; }
    .fc-fab:not(.hidden) { display: flex !important; }
    .floating-contact.mobile-open {
      display: flex !important;
      position: fixed;
      right: 16px;
      bottom: 140px;
      top: auto;
      transform: none;
    }
  }
  @media (min-width: 1025px) {
    .fc-fab { display: none !important; }
    .floating-contact.hidden { display: none !important; }
    .floating-contact:not(.hidden) { display: flex !important; }
  }
</style>

<script>
  function initFloatingContact() {
    var fc = document.getElementById('floatingContact');
    var fab = document.getElementById('fcFab');
    if (!fc || !fab) return;
    // Check if user previously closed
    if (sessionStorage.getItem('fc_closed') === '1') return;
    fc.classList.remove('hidden');
    if (window.innerWidth <= 1024) {
      fc.classList.add('hidden');
      fab.classList.remove('hidden');
    } else {
      fab.classList.add('hidden');
    }
  }
  function closeFloatingContact() {
    document.getElementById('floatingContact').classList.add('hidden');
    document.getElementById('fcFab').classList.add('hidden');
    sessionStorage.setItem('fc_closed', '1');
  }
  function toggleFloatingContact() {
    var fc = document.getElementById('floatingContact');
    fc.classList.toggle('mobile-open');
  }
  // Close mobile panel when clicking outside
  document.addEventListener('click', function(e) {
    var fc = document.getElementById('floatingContact');
    if (fc && fc.classList.contains('mobile-open') && !fc.contains(e.target) && e.target.id !== 'fcFab') {
      fc.classList.remove('mobile-open');
    }
  });
  window.addEventListener('resize', function() {
    var fc = document.getElementById('floatingContact');
    var fab = document.getElementById('fcFab');
    if (sessionStorage.getItem('fc_closed') === '1') return;
    if (window.innerWidth <= 1024) {
      fc.classList.add('hidden'); fc.classList.remove('mobile-open');
      fab.classList.remove('hidden');
    } else {
      fab.classList.add('hidden');
      fc.classList.remove('hidden'); fc.classList.remove('mobile-open');
    }
  });
  // Init on load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFloatingContact);
  } else {
    initFloatingContact();
  }
</script>
