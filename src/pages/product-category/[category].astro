---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { categoryTree, getCategory } from '../../data/categories';
import SEO from '../../components/SEO.astro';

export async function getStaticPaths() {
  return categoryTree.map(cat => ({ params: { category: cat.slug } }));
}

const { category } = Astro.params as { category: string };
const cat = getCategory(category);

if (!cat) {
  return Astro.redirect('/woshidahuaidan/products/');
}

const allProducts = await getCollection('products', ({ data }) => data.published);
const catProducts = allProducts.filter(p => p.data.category === cat.name);
const subParam = Astro.url.searchParams.get('sub');

const breadcrumb = { items: [
  { name: 'Home', url: new URL('/woshidahuaidan/', Astro.site).href },
  { name: cat.name, url: new URL(`/woshidahuaidan/product-category/${category}/`, Astro.site).href },
]};
---

<Layout title={cat.name} description={`Browse GRANGIN ${cat.name} - ${cat.subcategories.map(s=>s.name).join(', ')}. ISO 9001 certified manufacturer.`}>
  <SEO breadcrumb={breadcrumb} pageType="organization" />

  <section class="bg-dark-900 text-white py-12 sm:py-16">
    <div class="container-page">
      <p class="text-brand-400 font-semibold text-sm uppercase tracking-wider mb-2">Product Category</p>
      <h1 class="text-3xl sm:text-4xl font-black">{cat.icon} {cat.name}</h1>
      <p class="mt-3 text-steel-400">{catProducts.length} product{catProducts.length !== 1 ? 's' : ''} in this category</p>
    </div>
  </section>

  <section class="section-py">
    <div class="container-page">
      <!-- Subcategories -->
      <h2 class="text-xl font-bold text-steel-900 mb-4">Subcategories</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 mb-10">
        {cat.subcategories.map(sc => {
          const count = catProducts.filter(p => p.data.subcategory === sc.slug).length;
          return (
            <a href={`/woshidahuaidan/product-category/${category}/${sc.slug}/`} class="flex items-center gap-3 p-3.5 bg-steel-50 rounded-lg border border-steel-200 hover:border-brand-300 hover:shadow-md transition-all group">
              <span class="text-sm font-medium text-steel-700 group-hover:text-brand-600">{sc.name}</span>
              <span class="text-xs text-steel-400 ml-auto">({count})</span>
            </a>
          );
        })}
      </div>

      <!-- Products -->
      {catProducts.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
          {catProducts.map(p => (
            <a href={`/woshidahuaidan/product/${p.id}/`} class="card-base group flex flex-col">
              <div class="aspect-[4/3] bg-steel-100 flex items-center justify-center">
                <div class="text-center p-4"><div class="text-5xl mb-2">⚙️</div><span class="tag tag-red">{p.data.category}</span></div>
              </div>
              <div class="p-4 flex-1 flex flex-col">
                <span class="text-xs font-semibold text-brand-600 uppercase tracking-wide mb-1">{p.data.subcategory || p.data.category}</span>
                <h3 class="font-bold text-steel-900 group-hover:text-brand-600 transition-colors mb-2 line-clamp-2">{p.data.title}</h3>
                <p class="text-sm text-steel-500 leading-relaxed line-clamp-2 mb-3 flex-1">{p.data.excerpt}</p>
                <div class="flex items-center justify-between pt-3 border-t border-steel-100"><span class="stock-in">In Stock</span><span class="text-sm font-semibold text-brand-600">View →</span></div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-12"><p class="text-steel-500">Products coming soon. <a href="/woshidahuaidan/contact/" class="text-brand-600 font-semibold">Contact us</a> for your requirements.</p></div>
      )}
    </div>
  </section>
</Layout>
