---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { categoryTree, getCategory, getSubCategory } from '../../../data/categories';
import SEO from '../../../components/SEO.astro';

export async function getStaticPaths() {
  const paths: any[] = [];
  for (const cat of categoryTree) {
    for (const sc of cat.subcategories) {
      paths.push({ params: { category: cat.slug, subcategory: sc.slug } });
    }
  }
  return paths;
}

const { category, subcategory } = Astro.params as { category: string; subcategory: string };
const cat = getCategory(category);
const sc = getSubCategory(category, subcategory);

if (!cat || !sc) return Astro.redirect('/products/');

const allProducts = await getCollection('products', ({ data }) => data.published);
const products = allProducts.filter(p => p.data.category === cat.name && p.data.subcategory === subcategory);

const breadcrumb = { items: [
  { name: 'Home', url: new URL('/', Astro.site).href },
  { name: cat.name, url: new URL(`/product-category/${category}/`, Astro.site).href },
  { name: sc.name, url: new URL(`/product-category/${category}/${subcategory}/`, Astro.site).href },
]};
---

<Layout title={`${sc.name} | ${cat.name}`} description={`${sc.name} - ${cat.name} from GRANGIN. ISO 9001 certified China manufacturer. Custom sizes available.`}>
  <SEO breadcrumb={breadcrumb} pageType="organization" />

  <section class="bg-dark-900 text-white py-12 sm:py-16">
    <div class="container-page">
      <nav class="flex items-center gap-2 text-sm text-steel-400 mb-3">
        <a href="/" class="hover:text-white">Home</a><span>/</span>
        <a href={`/product-category/${category}/`} class="hover:text-white">{cat.name}</a><span>/</span>
        <span class="text-white font-semibold">{sc.name}</span>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-black">{sc.name}</h1>
      <p class="mt-3 text-steel-400">{products.length} product{products.length !== 1 ? 's' : ''} in {sc.name}</p>
    </div>
  </section>

  <section class="section-py">
    <div class="container-page">
      {products.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
          {products.map(p => (
            <a href={`/product/${p.id}/`} class="card-base group flex flex-col">
              <div class="aspect-[4/3] bg-steel-100 flex items-center justify-center">
                <div class="text-center p-4"><div class="text-5xl mb-2">⚙️</div><span class="tag tag-red">{p.data.category}</span></div>
              </div>
              <div class="p-4 flex-1 flex flex-col">
                <span class="text-xs font-semibold text-brand-600 uppercase tracking-wide mb-1">{p.data.subcategory || p.data.category}</span>
                <h3 class="font-bold text-steel-900 group-hover:text-brand-600 transition-colors mb-2 line-clamp-2">{p.data.title}</h3>
                <p class="text-sm text-steel-500 leading-relaxed line-clamp-2 mb-3 flex-1">{p.data.excerpt}</p>
                <div class="flex items-center justify-end pt-3 border-t border-steel-100"><span class="text-sm font-semibold text-brand-600">View →</span></div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16"><div class="text-6xl mb-4">📦</div><h3 class="text-xl font-bold text-steel-700 mb-2">Coming Soon</h3><p class="text-steel-500"><a href="/contact/" class="text-brand-600 font-semibold">Contact us</a> for custom orders.</p></div>
      )}
    </div>
  </section>
</Layout>
