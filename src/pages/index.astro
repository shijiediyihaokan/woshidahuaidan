---
// ============================================================
// index.astro — CTS-style homepage for Guangjin Gear
// ============================================================
import Layout from '../layouts/Layout.astro';

const stats = [
  { value: '150,000+', label: 'Products in Stock' },
  { value: '15+', label: 'Years Experience' },
  { value: '100+', label: 'Skilled Staff' },
  { value: '50+', label: 'Countries Exported' },
];

const qualityFeatures = [
  {
    title: 'Precision Gear Hobbing',
    desc: 'Every gear undergoes high-precision CNC hobbing and grinding to ensure optimal tooth profile accuracy. This process guarantees smooth power transmission and minimal noise under heavy loads.',
    icon: '⚙️',
  },
  {
    title: 'Advanced Heat Treatment',
    desc: 'Utilizing atmosphere-controlled carburizing furnaces, our gears achieve an optimal case-hardened depth. This creates a wear-resistant surface while maintaining a tough, shock-resistant core for extended service life.',
    icon: '🔥',
  },
  {
    title: 'Rigorous Testing',
    desc: 'All gearboxes undergo comprehensive load testing before leaving the factory. Every unit is tested at rated load to verify efficiency, noise levels, and temperature rise meet stringent quality standards.',
    icon: '✅',
  },
];

const featuredProducts = [
  {
    name: 'NMRV Series Worm Gearbox',
    category: 'Worm Gearbox',
    desc: 'Aluminum housing worm gearbox featuring compact design, high efficiency, and versatile mounting options. Ideal for conveyor systems, packaging machinery, and industrial automation.',
    href: '/products/nrmv-series-worm-gearbox/',
    specs: ['Size 025-150', 'Ratio 5:1 to 100:1', 'IEC Motor Flange'],
  },
  {
    name: 'R Series Helical Gearbox',
    category: 'Helical Gearbox',
    desc: 'Inline helical gearbox with efficiency up to 96% per stage. Hardened helical gears for quiet, reliable power transmission in industrial drives, pumps, and mixers.',
    href: '/products/r-series-helical-gearbox/',
    specs: ['Size R17-R167', 'Ratio 1.3:1 to 289:1', 'Foot & Flange Mount'],
  },
  {
    name: 'GM Series Gear Motor',
    category: 'Gear Motor',
    desc: 'Integrated gear motor combining high-efficiency electric motor with precision gearbox in one compact unit. Plug-and-play solution for conveyors, packaging, and automation.',
    href: '/products/gm-series-gear-motor/',
    specs: ['0.12kW-200kW', 'IE3/IE4 Efficiency', 'All Mounting Positions'],
  },
];

const categories = [
  { name: 'Worm Gearbox', icon: '⚙️', href: '/products/?category=worm-gearbox' },
  { name: 'Helical Gearbox', icon: '🔧', href: '/products/?category=helical-gearbox' },
  { name: 'Bevel Gearbox', icon: '🔄', href: '/products/?category=bevel-gearbox' },
  { name: 'Industrial Gearbox', icon: '🏭', href: '/products/?category=industrial-gearbox' },
  { name: 'Variator', icon: '📐', href: '/products/?category=variator' },
  { name: 'Gear Motor', icon: '⚡', href: '/products/?category=gear-motor' },
  { name: 'AC Motor', icon: '🔌', href: '/products/?category=ac-motor' },
  { name: 'Gears & Racks', icon: '🔗', href: '/products/?category=gear' },
  { name: 'Sprockets', icon: '🛞', href: '/products/?category=sprocket' },
  { name: 'Belt Pulleys', icon: '🔄', href: '/products/?category=belt-pulley' },
  { name: 'Couplings', icon: '🔩', href: '/products/?category=coupling' },
  { name: 'Sheet Metal', icon: '📏', href: '/products/?category=sheet-metal' },
];

const industries = [
  { name: 'Food & Beverage', desc: 'Hygienic, washdown-ready gearboxes for food processing and packaging lines.', icon: '🍽️' },
  { name: 'Material Handling', desc: 'Heavy-duty reducers for conveyors, elevators, and automated warehousing systems.', icon: '📦' },
  { name: 'Agricultural Machinery', desc: 'Robust gearboxes for harvesters, tillers, irrigation systems and farm equipment.', icon: '🚜' },
  { name: 'Packaging & Logistics', desc: 'Precision gearmotors for packaging machines, sortation, and logistics automation.', icon: '📋' },
  { name: 'Wood Processing', desc: 'High-torque reducers for sawmills, chippers, and wood processing equipment.', icon: '🪵' },
  { name: 'Lifting & Hoisting', desc: 'Safety-rated gearboxes for cranes, hoists, winches, and lifting applications.', icon: '🏗️' },
];

const testimonials = [
  { text: 'Guangjin gearboxes have been a key component in our production lines. Their products are reliable and their service is exceptional.', name: 'Peter Schneider', country: 'Germany' },
  { text: 'We\'ve been sourcing worm gearboxes from Guangjin for over 5 years. Consistent quality, competitive pricing, and always on-time delivery.', name: 'William Jones', country: 'United Kingdom' },
  { text: 'Their NMRV series gearboxes are the best we\'ve used. Excellent build quality and the technical support team is always responsive.', name: 'Thomas Schmidt', country: 'Germany' },
  { text: 'Guangjin is our go-to supplier for power transmission components. Great products, professional staff, and they always go the extra mile.', name: 'Juan García', country: 'Spain' },
];

const blogPosts = [
  { title: 'How to Select the Right Worm Gearbox', date: 'Jun 10, 2026', href: '/blog/select-worm-gearbox/' },
  { title: 'NMRV vs. NRV: Which Gearbox Is Right for Your Application?', date: 'May 28, 2026', href: '/blog/nrmv-vs-nrv/' },
  { title: 'Understanding Gearbox Efficiency Ratings', date: 'May 15, 2026', href: '/blog/gearbox-efficiency/' },
];
---

<Layout title="Home" description="Zhejiang Guangjin — Professional manufacturer of industrial gearboxes, gear motors, and power transmission components. 150,000+ products in stock. Trusted supplier in 50+ countries.">
  
  <!-- ============================================================
       Section 1: Hero Slider
       ============================================================ -->
  <section class="relative bg-gradient-to-br from-dark-900 via-dark-800 to-dark-900 text-white overflow-hidden" style="min-height: 500px;">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,_rgba(206,17,50,0.3),transparent_50%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_30%,_rgba(206,17,50,0.2),transparent_40%)]"></div>
    </div>
    <!-- Grid pattern overlay -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2240%22 height=%2240%22><rect width=%2240%22 height=%2240%22 fill=%22none%22 stroke=%22white%22 stroke-width=%220.5%22/></svg>')"></div>
    
    <div class="relative container-page py-20 sm:py-28 lg:py-36">
      <div class="max-w-3xl">
        <p class="text-brand-400 font-semibold text-lg mb-3 animate-fade-in-up">Transmit Force, Drive Future</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight leading-tight mb-6 animate-fade-in-up">
          Industrial Gearbox &<br>
          <span class="text-brand-400">Power Transmission</span> Manufacturer
        </h1>
        <p class="text-lg sm:text-xl text-steel-300 max-w-2xl leading-relaxed mb-8 animate-fade-in-up">
          Professional manufacturer of worm gearboxes, helical gearboxes, gear motors, and complete power transmission solutions. 150,000+ products in stock — trusted by customers in 50+ countries worldwide.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up">
          <a href="/products/" class="btn-primary text-base px-8 py-3.5">
            Browse Products →
          </a>
          <a href="/contact/" class="btn-white text-base px-8 py-3.5">
            Request Quote
          </a>
        </div>
      </div>
    </div>

    <!-- Slide indicators -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-3">
      <span class="w-3 h-3 rounded-full bg-brand-600"></span>
      <span class="w-3 h-3 rounded-full bg-white/30"></span>
      <span class="w-3 h-3 rounded-full bg-white/30"></span>
      <span class="w-3 h-3 rounded-full bg-white/30"></span>
      <span class="w-3 h-3 rounded-full bg-white/30"></span>
    </div>
  </section>

  <!-- ============================================================
       Section 2: Stats Bar
       ============================================================ -->
  <section class="bg-white border-b border-steel-200">
    <div class="container-page py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {stats.map((stat) => (
          <div class="group">
            <div class="text-3xl sm:text-4xl font-black text-brand-600 group-hover:scale-110 transition-transform duration-300">{stat.value}</div>
            <div class="mt-2 text-sm text-steel-500 font-medium">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       Section 3: Quality Features (High Endurance Low Maintenance)
       ============================================================ -->
  <section class="section-py bg-steel-50">
    <div class="container-page">
      <h2 class="section-title">
        High Endurance <span class="text-brand-600">Low Maintenance</span>
      </h2>
      <p class="section-subtitle">
        Every Guangjin gearbox is engineered for maximum durability and minimal downtime. Our manufacturing excellence is built on three core processes.
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {qualityFeatures.map((feature) => (
          <div class="card-base p-8">
            <div class="text-4xl mb-4">{feature.icon}</div>
            <h3 class="text-lg font-bold text-steel-900 mb-3">{feature.title}</h3>
            <p class="text-sm text-steel-500 leading-relaxed">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       Section 4: Featured Products
       ============================================================ -->
  <section class="section-py bg-white">
    <div class="container-page">
      <h2 class="section-title">Popular Industrial <span class="text-brand-600">Gearbox Types</span></h2>
      <p class="section-subtitle">
        Choose Guangjin for a seamless partnership that meets your industry needs with superior-quality gearboxes to keep you running!
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {featuredProducts.map((product) => (
          <a href={product.href} class="card-base group">
            <!-- Image placeholder -->
            <div class="aspect-[4/3] bg-steel-100 flex items-center justify-center">
              <div class="text-center p-4">
                <div class="text-5xl mb-2">⚙️</div>
                <span class="tag tag-red">{product.category}</span>
              </div>
            </div>
            <div class="p-5">
              <h3 class="font-bold text-steel-900 group-hover:text-brand-600 transition-colors mb-2">{product.name}</h3>
              <p class="text-sm text-steel-500 leading-relaxed mb-4 line-clamp-3">{product.desc}</p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                {product.specs.map((spec) => (
                  <span class="text-[10px] bg-steel-100 text-steel-600 px-2 py-0.5 rounded-full font-medium">{spec}</span>
                ))}
              </div>
              <span class="text-sm font-semibold text-brand-600 group-hover:text-brand-700 transition-colors">
                Learn More →
              </span>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/products/" class="btn-outline">
          View All Products →
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       Section 5: Product Categories Grid
       ============================================================ -->
  <section class="section-py bg-steel-50">
    <div class="container-page">
      <h2 class="section-title">Complete <span class="text-brand-600">Product Range</span></h2>
      <p class="section-subtitle">
        From standard gearboxes to custom power transmission solutions — we manufacture a comprehensive range of industrial drive components.
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        {categories.map((cat) => (
          <a href={cat.href} class="flex items-center gap-3 p-3.5 bg-white rounded-lg border border-steel-200 hover:border-brand-300 hover:shadow-md transition-all group">
            <span class="text-xl shrink-0">{cat.icon}</span>
            <span class="text-sm font-medium text-steel-700 group-hover:text-brand-600 transition-colors leading-tight">{cat.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       Section 6: Industries Served
       ============================================================ -->
  <section class="section-py bg-white">
    <div class="container-page">
      <h2 class="section-title">Industries <span class="text-brand-600">We Serve</span></h2>
      <p class="section-subtitle">
        Guangjin provides reliable power transmission solutions for a diverse range of industries worldwide.
      </p>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {industries.map((ind) => (
          <div class="card-base p-5 text-center group">
            <div class="text-3xl mb-3">{ind.icon}</div>
            <h4 class="text-sm font-bold text-steel-800 mb-2">{ind.name}</h4>
            <p class="text-xs text-steel-500 leading-relaxed">{ind.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       Section 7: Testimonials
       ============================================================ -->
  <section class="section-py bg-dark-900 text-white">
    <div class="container-page">
      <h2 class="text-3xl font-black text-center mb-3">What Our <span class="text-brand-400">Customers Say</span></h2>
      <p class="text-steel-400 text-center max-w-xl mx-auto mb-10">
        We don't view ourselves as just a supplier — we're a business partner committed to your success.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {testimonials.map((t) => (
          <div class="bg-dark-800 rounded-lg p-6 border border-dark-700">
            <div class="text-brand-400 text-2xl mb-3">"</div>
            <p class="text-sm text-steel-300 leading-relaxed mb-4">{t.text}</p>
            <div class="border-t border-dark-700 pt-3">
              <p class="text-sm font-semibold text-white">{t.name}</p>
              <p class="text-xs text-steel-500">{t.country}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       Section 8: Blog & Resources
       ============================================================ -->
  <section class="section-py bg-steel-50">
    <div class="container-page">
      <h2 class="section-title">Latest <span class="text-brand-600">Resources</span></h2>
      <p class="section-subtitle">
        Expert guides and insights to help you select and maintain the right power transmission products.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {blogPosts.map((post) => (
          <a href={post.href} class="card-base p-6 group">
            <p class="text-xs text-steel-400 mb-2">{post.date}</p>
            <h4 class="font-bold text-steel-800 group-hover:text-brand-600 transition-colors mb-2">{post.title}</h4>
            <span class="text-sm font-semibold text-brand-600 group-hover:text-brand-700 transition-colors">
              Read More →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       Section 9: CTA — Ask the Experts
       ============================================================ -->
  <section class="py-16 sm:py-20 bg-brand-600 text-white">
    <div class="container-page text-center">
      <h2 class="text-3xl sm:text-4xl font-black mb-4">Ask the Experts</h2>
      <p class="text-brand-100 text-lg max-w-2xl mx-auto mb-8 leading-relaxed">
        Having trouble finding the product you need? Send us your requirements and we'll quickly respond with tailored solutions. Expect top-notch precision, reliability, efficiency, and performance.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="btn-white text-base px-8 py-3.5 font-bold">
          Get in Touch
        </a>
        <a href="mailto:info@ggn-gear.com" class="inline-flex items-center justify-center px-8 py-3.5 border-2 border-white text-white font-bold rounded-lg hover:bg-white/10 transition-colors text-base">
          info@ggn-gear.com
        </a>
      </div>
    </div>
  </section>

</Layout>
