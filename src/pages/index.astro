---
import Layout from '../layouts/Layout.astro';
import { categoryTree } from '../data/categories';
import { getCollection } from 'astro:content';

// Count products per category
const products = await getCollection('products', ({ data }) => data.published);
const catCounts: Record<string,number> = {};
products.forEach(p => { const c = p.data.category; catCounts[c] = (catCounts[c]||0)+1; });
const populatedCats = categoryTree.filter(cat => catCounts[cat.name] > 0);

// Load news
const newsArticles = await getCollection('news', ({ data }) => data.published);
const latestNews = newsArticles.sort((a,b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 3);

const stats = [
  { value: '20+', label: 'Years Experience', desc: 'In power transmission' },
  { value: '10,000㎡', label: 'Factory Area', desc: 'Advanced facility' },
  { value: '25,000+', label: 'Monthly Output', desc: 'Pieces per month' },
  { value: '50+', label: 'Countries Served', desc: 'Global reach' },
];

const advantages = [
  {
    title: 'Engineering Excellence',
    desc: 'Chief Engineer with 30+ years of automation expertise. Engineering team averaging 15+ years of experience. Comprehensive 3D design blueprints for every project.',
    icon: `<svg class="w-10 h-10" fill="none" stroke="#CE1132" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`
  },
  {
    title: 'Quality Assurance',
    desc: 'ISO 9001, 45001, 14001 certified. 25+ dedicated QC professionals. Three-stage manual inspection process. Coordinate measuring machines and gear profile testers.',
    icon: `<svg class="w-10 h-10" fill="none" stroke="#CE1132" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`
  },
  {
    title: 'Rapid Response',
    desc: '12-hour guaranteed response for all inquiries. Priority fast-track for urgent orders. Optimized production scheduling. Export-grade packaging for safe delivery.',
    icon: `<svg class="w-10 h-10" fill="none" stroke="#CE1132" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`
  },
  {
    title: 'Custom Manufacturing',
    desc: 'Full OEM/ODM support with 35+ materials. CNC machining, laser cutting, sheet metal fabrication. One-to-one design solutions tailored to your exact specifications.',
    icon: `<svg class="w-10 h-10" fill="none" stroke="#CE1132" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>`
  },
];

const industries = [
  'Grain & Oil', 'Lifting', 'Mining', 'Tobacco', 'Aircraft',
  'Automotive', 'Conveying', 'Elevator', 'Textile', 'Manufacturing',
  'Mould', 'Railway', 'Marine',
];

const testimonials = [
  { text: 'GRANGIN has been our trusted partner for custom transmission components. Consistent quality and highly professional engineering support.', name: 'Peter Schneider', role: 'Germany' },
  { text: 'We source sprockets and chains from GRANGIN. Fast delivery, competitive pricing, and excellent customer service.', name: 'William Jones', role: 'United Kingdom' },
  { text: 'Outstanding CNC machining capabilities. Complex custom parts delivered with precision and on schedule.', name: 'Thomas Schmidt', role: 'Germany' },
  { text: 'Our go-to supplier for power transmission. One-to-one design solutions and rigorous quality control.', name: 'Juan García', role: 'Spain' },
];

---

<Layout title="Home" description="Ceten by GRANGIN — Professional manufacturer of industrial gears, sprockets, gearboxes, and CNC machined parts. ISO 9001 certified. Custom manufacturing with 20+ years experience.">
  
  <!-- ============ HERO ============ -->
  <section class="relative bg-dark-900 text-white overflow-hidden" style="min-height: 520px;">
    <!-- Background pattern -->
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_40%,_rgba(206,17,50,0.15),transparent_50%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_80%_60%,_rgba(206,17,50,0.1),transparent_40%)]"></div>
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2260%22 height=%2260%22><circle cx=%2230%22 cy=%2230%22 r=%221%22 fill=%22white%22/></svg>')"></div>
    </div>

    <div class="relative container-page py-20 sm:py-28 lg:py-36">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-brand-600/20 border border-brand-500/30 rounded-full text-brand-300 text-xs font-semibold mb-6">
          <span class="w-2 h-2 bg-brand-500 rounded-full animate-pulse"></span>
          ISO 9001 · 45001 · 14001 Certified Manufacturer
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight leading-[1.1] mb-6">
          Precision Power Transmission<br>
          <span class="text-brand-400">Components & Solutions</span>
        </h1>
        <p class="text-lg text-steel-300 max-w-2xl leading-relaxed mb-8">
          Custom gears, sprockets, gearboxes, and CNC machined parts — engineered for reliability. 
          20+ years of manufacturing excellence serving customers in 50+ countries.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/product-category/gearboxes/" class="btn-primary text-base px-8 py-3.5">Explore Products</a>
          <a href="/contact/" class="btn-white text-base px-8 py-3.5">Get a Quote</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ STATS ============ -->
  <section class="bg-white border-b border-steel-200">
    <div class="container-page">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-steel-100">
        {stats.map((stat, i) => (
          <div class="py-8 px-4 text-center group">
            <div class="text-3xl sm:text-4xl font-black text-brand-600 mb-1 group-hover:scale-110 transition-transform duration-300">{stat.value}</div>
            <div class="text-sm font-semibold text-steel-800">{stat.label}</div>
            <div class="text-xs text-steel-400 mt-1">{stat.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ WHY CHOOSE US ============ -->
  <section class="section-py bg-steel-50">
    <div class="container-page">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-black text-steel-900 mb-3">
          Why Choose <span class="text-brand-600">GRANGIN</span>
        </h2>
        <p class="text-steel-500 text-lg max-w-2xl mx-auto">
          A nationally recognized high-tech enterprise with proven manufacturing capabilities and ISO-certified quality systems.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {advantages.map((adv) => (
          <div class="card-base p-6 group hover:border-brand-300">
            <div class="mb-4 w-12 h-12 bg-brand-50 rounded-lg flex items-center justify-center group-hover:bg-brand-100 transition-colors">
              <span set:html={adv.icon} />
            </div>
            <h3 class="text-base font-bold text-steel-900 mb-2">{adv.title}</h3>
            <p class="text-sm text-steel-500 leading-relaxed">{adv.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ OUR HISTORY ============ -->
  <section class="section-py bg-white">
    <div class="container-page">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-black text-steel-900 mb-3">
          Our <span class="text-brand-600">History</span>
        </h2>
        <p class="text-steel-500 text-lg max-w-2xl mx-auto">
          Two decades of precision engineering — from a small workshop to a nationally recognized high-tech enterprise.
        </p>
      </div>

      <div class="relative max-w-4xl mx-auto">
        <!-- Timeline line -->
        <div class="absolute left-8 md:left-1/2 top-0 bottom-0 w-0.5 bg-steel-200 -translate-x-1/2 hidden md:block"></div>
        <div class="absolute left-8 top-0 bottom-0 w-0.5 bg-steel-200 md:hidden"></div>

        {[
          { year: '2005', title: 'Company Founded', desc: 'Established as a precision gear manufacturer in Zhejiang Province with a single workshop and 15 employees.' },
          { year: '2012', title: 'ISO 9001 Certified', desc: 'Achieved ISO 9001 quality management certification. Expanded product line to include gearboxes and speed variators.' },
          { year: '2016', title: 'Factory Modernization', desc: 'Relocated to a new 10,000㎡ modern facility in Sanjie High-tech Park. Introduced CNC machining and automated production lines.' },
          { year: '2018', title: 'ISO 14001 & 45001', desc: 'Certified for environmental management (ISO 14001) and occupational health & safety (ISO 45001). Began exporting to European markets.' },
          { year: '2022', title: 'National High-Tech Enterprise', desc: 'Recognized as a National High-Tech Enterprise. Launched the GRANGIN brand with a focus on intelligent manufacturing.' },
          { year: '2025', title: 'Global Reach', desc: 'Products exported to 50+ countries. 25,000+ pieces monthly output. Ranked among top transmission manufacturers in East China.' },
        ].map((item, i) => (
          <div class={`relative flex items-start gap-6 mb-10 md:mb-14 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
            {/* Timeline dot */}
            <div class="absolute left-8 md:left-1/2 w-4 h-4 bg-brand-600 rounded-full border-4 border-brand-100 -translate-x-1/2 z-10 mt-1.5 hidden md:block"></div>
            <div class="absolute left-8 w-4 h-4 bg-brand-600 rounded-full border-4 border-brand-100 -translate-x-1/2 z-10 mt-1.5 md:hidden"></div>

            {/* Content card */}
            <div class={`ml-16 md:ml-0 md:w-1/2 ${i % 2 === 0 ? 'md:pr-14 md:text-right' : 'md:pl-14'}`}>
              <div class={`bg-steel-50 border border-steel-100 rounded-xl p-6 ${i % 2 === 0 ? 'md:text-left' : ''}`}>
                <span class="inline-block px-3 py-1 bg-brand-600 text-white text-xs font-bold rounded-full mb-3">{item.year}</span>
                <h3 class="text-lg font-bold text-steel-900 mb-2">{item.title}</h3>
                <p class="text-sm text-steel-500 leading-relaxed">{item.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ PRODUCT CATEGORIES ============ -->
  <section class="section-py bg-white">
    <div class="container-page">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-black text-steel-900 mb-3">
          Product <span class="text-brand-600">Categories</span>
        </h2>
        <p class="text-steel-500 text-lg max-w-2xl mx-auto">
          Comprehensive range of power transmission components and custom manufacturing services.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {populatedCats.map((cat) => (
          <a href={`/product-category/${cat.slug}`} class="card-base p-5 group text-center hover:border-brand-300">
            <span class="text-3xl block mb-3">{cat.icon}</span>
            <h3 class="text-sm font-bold text-steel-800 group-hover:text-brand-600 transition-colors">{cat.name}</h3>
            <p class="text-xs text-steel-400 mt-1.5">{catCounts[cat.name]} products</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ VIDEO ============ -->
  <section class="section-py bg-steel-50">
    <div class="container-page">
      <div class="text-center mb-10">
        <h2 class="text-3xl sm:text-4xl font-black text-steel-900 mb-3">
          See Our <span class="text-brand-600">Factory</span> in Action
        </h2>
        <p class="text-steel-500 text-lg max-w-2xl mx-auto">
          Take a virtual tour of our 10,000㎡ advanced manufacturing facility. See how precision components are made from raw material to finished product.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="relative aspect-video rounded-2xl overflow-hidden bg-dark-900 shadow-2xl border border-steel-200">
          <!-- Video embed placeholder — replace src with actual YouTube/Vimeo URL -->
          <iframe 
            class="absolute inset-0 w-full h-full"
            src="https://www.youtube.com/embed/REPLACE_WITH_YOUR_VIDEO_ID?rel=0&modestbranding=1"
            title="GRANGIN Factory Tour"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
          <!-- Overlay when no video is set -->
          <div class="absolute inset-0 flex items-center justify-center bg-dark-900/80 pointer-events-none peer" id="videoPlaceholder">
            <div class="text-center">
              <div class="w-20 h-20 mx-auto mb-4 bg-brand-600/20 rounded-full flex items-center justify-center">
                <svg class="w-10 h-10 text-brand-400" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </div>
              <p class="text-steel-300 text-sm">Factory Tour Video Coming Soon</p>
            </div>
          </div>
        </div>
        <p class="text-center text-xs text-steel-400 mt-4">
          💡 Replace the YouTube video ID in <code class="bg-steel-100 px-1.5 py-0.5 rounded text-xs">index.astro</code> with your actual factory tour video
        </p>
      </div>
    </div>
  </section>

  <!-- ============ INDUSTRIES ============ -->
  <section class="section-py bg-dark-900 text-white">
    <div class="container-page text-center">
      <h2 class="text-3xl sm:text-4xl font-black mb-3">
        Industries <span class="text-brand-400">We Serve</span>
      </h2>
      <p class="text-steel-400 text-lg max-w-2xl mx-auto mb-10">
        Reliable power transmission solutions for diverse industrial applications worldwide.
      </p>
      <div class="flex flex-wrap justify-center gap-3 max-w-4xl mx-auto">
        {industries.map((ind) => (
          <span class="px-4 py-2.5 bg-dark-800 border border-dark-700 rounded-lg text-sm font-medium text-steel-300 hover:border-brand-500/50 hover:text-white transition-colors">
            {ind}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ TESTIMONIALS ============ -->
  <section class="section-py bg-white">
    <div class="container-page">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-black text-steel-900 mb-3">
          Trusted by <span class="text-brand-600">Customers Worldwide</span>
        </h2>
        <p class="text-steel-500 text-lg max-w-2xl mx-auto">
          Multi-awarded as "Integrity Enterprise" and "Grade-A Taxpayer" by authorities.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {testimonials.map((t) => (
          <div class="bg-steel-50 rounded-xl p-6 border border-steel-100">
            <div class="flex gap-1 mb-3">
              {[1,2,3,4,5].map(() => <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}
            </div>
            <p class="text-sm text-steel-600 leading-relaxed mb-4">"{t.text}"</p>
            <div class="border-t border-steel-200 pt-3">
              <p class="text-sm font-bold text-steel-800">{t.name}</p>
              <p class="text-xs text-steel-400">{t.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ NEWS ============ -->
  <section class="section-py bg-steel-50">
    <div class="container-page">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-black text-steel-900 mb-3">
          Latest <span class="text-brand-600">Insights</span>
        </h2>
        <p class="text-steel-500 text-lg">Technical guides and industry updates from our engineering team.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {latestNews.length > 0 ? latestNews.map((item) => (
          <a href={`/news/${item.id}/`} class="card-base p-6 group">
            <p class="text-xs text-steel-400 mb-2">{new Date(item.data.date).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' })}</p>
            <h3 class="font-bold text-steel-800 group-hover:text-brand-600 transition-colors mb-2 leading-snug">{item.data.title}</h3>
            <span class="text-sm font-semibold text-brand-600">Read Article →</span>
          </a>
        )) : (
          <div class="col-span-3 text-center text-steel-400 py-8"><p>News articles coming soon. Check back for technical guides and industry updates.</p></div>
        )}
      </div>
    </div>
  </section>

  <!-- ============ SOCIAL MEDIA ============ -->
  <section class="py-16 bg-white">
    <div class="container-page text-center">
      <h2 class="text-3xl sm:text-4xl font-black text-steel-900 mb-3">
        Connect <span class="text-brand-600">With Us</span>
      </h2>
      <p class="text-steel-500 text-lg max-w-2xl mx-auto mb-10">
        Follow GRANGIN on social media for product updates, industry insights, and behind-the-scenes content from our factory.
      </p>

      <div class="flex flex-wrap justify-center gap-4 max-w-3xl mx-auto">
        {[
          { name: 'LinkedIn', icon: 'M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2zM4 6a2 2 0 100-4 2 2 0 000 4z', url: '#', color: 'hover:bg-[#0A66C2]' },
          { name: 'YouTube', icon: 'M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zM9 16V8l8 4-8 4z', url: '#', color: 'hover:bg-[#FF0000]' },
          { name: 'Facebook', icon: 'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z', url: '#', color: 'hover:bg-[#1877F2]' },
          { name: 'WeChat', icon: 'M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 01.598.082l1.584.926a.272.272 0 00.14.047c.134 0 .24-.111.24-.247 0-.06-.023-.12-.038-.177l-.327-1.233a.582.582 0 01-.023-.156.49.49 0 01.201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.952-7.062-6.122zm-2.18 2.769c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.434-.982.97-.982zm4.844 0c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.434-.982.97-.982z', url: '#', color: 'hover:bg-[#07C160]' },
          { name: 'TikTok', icon: 'M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z', url: '#', color: 'hover:bg-[#000000]' },
        ].map((social) => (
          <a 
            href={social.url} 
            target="_blank" 
            rel="noopener noreferrer"
            class={`group flex flex-col items-center gap-2 p-5 rounded-xl bg-steel-50 border border-steel-100 transition-all duration-300 ${social.color} hover:text-white hover:scale-105 hover:shadow-lg min-w-[120px]`}
            title={social.name}
          >
            <svg class="w-7 h-7 transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d={social.icon}/>
            </svg>
            <span class="text-sm font-semibold">{social.name}</span>
          </a>
        ))}
      </div>

      <p class="text-xs text-steel-400 mt-6">
        🔗 Update social media links in <code class="bg-steel-100 px-1.5 py-0.5 rounded text-xs">index.astro</code> → replace <code class="bg-steel-100 px-1.5 py-0.5 rounded text-xs">#</code> with actual profile URLs
      </p>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="py-20 bg-gradient-to-br from-brand-700 to-brand-600 text-white text-center">
    <div class="container-page max-w-2xl">
      <h2 class="text-3xl sm:text-4xl font-black mb-4">Start Your Project Today</h2>
      <p class="text-brand-100 text-lg mb-8 leading-relaxed">
        Send us your drawings or specifications. Our engineering team responds within 12 hours with a tailored solution and 3D design blueprint.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="btn-white text-base px-8 py-3.5 font-bold">Request a Quote</a>
        <a href="mailto:info@ggn-gear.com" class="inline-flex items-center justify-center px-8 py-3.5 border-2 border-white/60 text-white font-semibold rounded-lg hover:bg-white/10 hover:border-white transition-all text-base">
          info@ggn-gear.com
        </a>
      </div>
    </div>
  </section>

</Layout>
