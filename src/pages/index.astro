---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ProductCard from '../components/ProductCard.astro';

const products = await getCollection('products', ({ data }) => data.published);
const featured = products
  .filter((p) => ['Worm Gearbox', 'Helical Gearbox', 'Gear Motor'].includes(p.data.category))
  .slice(0, 6);

const stats = [
  { label: 'Years Experience', value: '15+' },
  { label: 'Products', value: '800+' },
  { label: 'Countries Exported', value: '50+' },
  { label: 'Categories', value: '12' },
];
---

<Layout title="Home" description="Zhejiang Guangjin — Industrial gearboxes, gear motors, and power transmission components manufacturer in China.">
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-steel-900 via-steel-800 to-brand-900 text-white overflow-hidden">
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNjAiIGhlaWdodD0iNjAiIHZpZXdCb3g9IjAgMCA2MCA2MCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48ZyBmaWxsPSJub25lIiBmaWxsLXJ1bGU9ImV2ZW5vZGQiPjxnIGZpbGw9IiNmZmYiIGZpbGwtb3BhY2l0eT0iMC4wMyI+PGNpcmNsZSBjeD0iMzAiIGN5PSIzMCIgcj0iMiIvPjwvZz48L2c+PC9zdmc+')] opacity-50"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-32">
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight">
          Precision Industrial<br />
          <span class="text-brand-300">Transmission Solutions</span>
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-steel-300 max-w-2xl leading-relaxed">
          Professional manufacturer of worm gearboxes, helical gearboxes, gear motors, and power transmission components. Trusted by customers in 50+ countries worldwide.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a
            href="/products/"
            class="inline-flex items-center justify-center px-6 py-3 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-500 transition-colors shadow-lg"
          >
            Browse Products
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a
            href="/contact/"
            class="inline-flex items-center justify-center px-6 py-3 border border-steel-500 text-white font-semibold rounded-lg hover:bg-white/10 transition-colors"
          >
            Request Quote
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-white border-b border-steel-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-3xl font-bold text-brand-600">{stat.value}</div>
            <div class="mt-1 text-sm text-steel-500">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-steel-900">Featured Products</h2>
        <p class="mt-3 text-steel-500 max-w-2xl mx-auto">
          Explore our range of industrial gearboxes and transmission components — engineered for reliability and performance.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featured.map((product) => <ProductCard product={product} />)}
      </div>

      <div class="text-center mt-10">
        <a
          href="/products/"
          class="inline-flex items-center px-6 py-3 bg-steel-100 text-steel-700 font-semibold rounded-lg hover:bg-steel-200 transition-colors text-sm"
        >
          View All Products
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="py-16 bg-steel-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-steel-900 text-center mb-10">Product Categories</h2>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {[
          { name: 'Worm Gearbox', icon: '⚙️' },
          { name: 'Helical Gearbox', icon: '🔧' },
          { name: 'Bevel Gearbox', icon: '🔄' },
          { name: 'Industrial Gearbox', icon: '🏭' },
          { name: 'Variator', icon: '📐' },
          { name: 'Gear Motor', icon: '⚡' },
          { name: 'AC Motor', icon: '🔌' },
          { name: 'Gear', icon: '⚙️' },
          { name: 'Sprocket', icon: '🔗' },
          { name: 'Belt Pulley', icon: '🛞' },
          { name: 'Coupling', icon: '🔩' },
          { name: 'Sheet Metal', icon: '📏' },
        ].map((cat) => (
          <a
            href={`/products/?category=${encodeURIComponent(cat.name)}`}
            class="group flex items-center gap-3 p-4 bg-white rounded-xl border border-steel-200 hover:border-brand-300 hover:shadow-md transition-all"
          >
            <span class="text-2xl">{cat.icon}</span>
            <span class="text-sm font-medium text-steel-700 group-hover:text-brand-600">{cat.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-brand-700 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold">Need a Custom Solution?</h2>
      <p class="mt-4 text-brand-100 text-lg max-w-2xl mx-auto">
        We provide OEM/ODM services. Tell us your specifications and we'll deliver the right product for your application.
      </p>
      <a
        href="/contact/"
        class="mt-8 inline-flex items-center px-8 py-3 bg-white text-brand-700 font-bold rounded-lg hover:bg-brand-50 transition-colors shadow-lg"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
