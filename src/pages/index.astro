---
import Layout from '../layouts/Layout.astro';

const stats = [
  { value: '10,000+', label: 'Factory Area (m²)' },
  { value: '20+', label: 'Years Experience' },
  { value: '100+', label: 'Team Members' },
  { value: '25,000+', label: 'Monthly Output (pcs)' },
];

const qualityFeatures = [
  { title: 'Expert Customization', desc: 'Accommodates diverse sizes and quantity requirements. Chief Engineer with 30+ years in automation expertise. Average engineering team tenure exceeding 15 years. Comprehensive 3D custom design blueprints provided.', icon: '🎯' },
  { title: 'Reliable Custom Service', desc: '12-hour response guarantee for all inquiries. Prompt quotation and customized solution feedback. Seamless collaboration between sales and technical teams.', icon: '⏱️' },
  { title: 'Rapid Delivery Assurance', desc: 'Priority fast-track for urgent orders. Optimized production scheduling coordination. Strict adherence to precision, hardness and quality standards.', icon: '🚀' },
];

const categories = [
  { name: 'Gear', icon: '⚙️', href: '/products/?category=gear' },
  { name: 'Sprocket', icon: '🔗', href: '/products/?category=sprocket' },
  { name: 'Belt Pulley', icon: '🔄', href: '/products/?category=belt-pulley' },
  { name: 'Coupling', icon: '🔩', href: '/products/?category=coupling' },
  { name: 'Transmission Shaft', icon: '📏', href: '/products/?category=transmission-shaft' },
  { name: 'Lead Screw', icon: '🔨', href: '/products/?category=lead-screw' },
  { name: 'Customized Parts', icon: '🖥️', href: '/products/?category=customized-parts' },
  { name: 'Transmission Parts', icon: '🏭', href: '/products/?category=transmission-parts' },
  { name: 'Sheet Metal', icon: '🏗️', href: '/products/?category=sheet-metal-components' },
  { name: 'Gear Motor', icon: '⚡', href: '/products/?category=gear-motor' },
  { name: 'Gearbox', icon: '🪱', href: '/products/?category=gearbox' },
  { name: 'AC Motor', icon: '🔌', href: '/products/?category=ac-motor' },
];

const industries = [
  { name: 'Grain & Oil Equipment', desc: 'Reliable power transmission for grain processing and oil extraction machinery.', icon: '🌾' },
  { name: 'Lifting Equipment', desc: 'Safety-rated components for cranes, hoists, and material lifting systems.', icon: '🏗️' },
  { name: 'Mining Equipment', desc: 'Heavy-duty gears and sprockets for demanding mining and quarrying operations.', icon: '⛏️' },
  { name: 'Tobacco Equipment', desc: 'Precision components for tobacco processing and packaging production lines.', icon: '🚬' },
  { name: 'Aircraft Manufacturing', desc: 'High-precision CNC machined parts meeting aerospace-grade tolerances.', icon: '✈️' },
  { name: 'Automotive', desc: 'Custom gears and shafts for automotive assembly and component manufacturing.', icon: '🚗' },
  { name: 'Conveying Equipment', desc: 'Sprockets, chains, and drive components for conveyor systems of all types.', icon: '📦' },
  { name: 'Elevators', desc: 'Precision gear components for passenger and freight elevator drive systems.', icon: '🛗' },
  { name: 'Garment Factories', desc: 'Custom mechanical parts for textile and garment manufacturing machinery.', icon: '👕' },
  { name: 'Mechanical Manufacturing', desc: 'Broad range of transmission parts for general mechanical equipment manufacturing.', icon: '🏭' },
  { name: 'Mould Equipment', desc: 'Precision-machined components for injection moulding and die-casting equipment.', icon: '🔧' },
  { name: 'Railway', desc: 'Durable power transmission parts for railway maintenance and track equipment.', icon: '🚂' },
  { name: 'Shipyard', desc: 'Large-scale custom gears and shafts for marine and shipbuilding applications.', icon: '🚢' },
];

const testimonials = [
  { text: 'GRANGIN has been our trusted partner for custom gears. Their quality is consistent and their engineering team is highly professional.', name: 'Peter Schneider', country: 'Germany' },
  { text: 'We rely on GRANGIN for our sprocket and chain needs. Fast delivery, competitive pricing, and excellent customer support.', name: 'William Jones', country: 'United Kingdom' },
  { text: 'Their CNC machining capabilities are outstanding. Complex custom parts delivered with precision and on schedule.', name: 'Thomas Schmidt', country: 'Germany' },
  { text: 'GRANGIN is our go-to supplier for transmission components. One-to-one design solutions and strict quality control — they never disappoint.', name: 'Juan García', country: 'Spain' },
];

const blogPosts = [
  { title: 'Are Worm Gearboxes Self-Locking?', date: 'Jun 05, 2026', href: '/news/are-worm-gearboxes-self-locking/' },
  { title: 'Top 10 China Worm Gear Motor Manufacturers In 2026', date: 'May 19, 2026', href: '/news/top-10-worm-gear-motor-manufacturers/' },
  { title: 'Top 10 China AC Gear Motor Manufacturers In 2026', date: 'May 19, 2026', href: '/news/top-10-ac-gear-motor-manufacturers/' },
];
---

<Layout title="Home" description="Zhejiang Guangjin Intelligent Technology Co., Ltd. — China professional manufacturer of gears, sprockets, belt pulleys, gear motors & CNC machined parts. 20+ years experience, ISO 9001/45001/14001 certified.">
  
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-dark-900 via-dark-800 to-dark-900 text-white overflow-hidden" style="min-height: 500px;">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,_rgba(206,17,50,0.3),transparent_50%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_30%,_rgba(206,17,50,0.2),transparent_40%)]"></div>
    </div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2240%22 height=%2240%22><rect width=%2240%22 height=%2240%22 fill=%22none%22 stroke=%22white%22 stroke-width=%220.5%22/></svg>')"></div>
    
    <div class="relative container-page py-20 sm:py-28 lg:py-36">
      <div class="max-w-3xl">
        <p class="text-brand-400 font-semibold text-lg mb-3 animate-fade-in-up">20+ Years Focus on Transmission Industry</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight leading-tight mb-6 animate-fade-in-up">
          CNC Professional Customized<br>
          <span class="text-brand-400">Mechanical Parts</span> Manufacturer
        </h1>
        <p class="text-lg sm:text-xl text-steel-300 max-w-2xl leading-relaxed mb-8 animate-fade-in-up">
          High Precision, High Hardness, Good Materials. Professional Supplier in Gear Motor — One-to-one Design Solutions, Strict Control of Production Quality Inspection, Professional Export Packaging.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up">
          <a href="/products/" class="btn-primary text-base px-8 py-3.5">Browse Products →</a>
          <a href="/contact/" class="btn-white text-base px-8 py-3.5">Request Quote</a>
        </div>
      </div>
    </div>

    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex gap-3">
      <span class="w-3 h-3 rounded-full bg-brand-600"></span>
      <span class="w-3 h-3 rounded-full bg-white/30"></span>
      <span class="w-3 h-3 rounded-full bg-white/30"></span>
      <span class="w-3 h-3 rounded-full bg-white/30"></span>
    </div>
  </section>

  <!-- Certifications Bar -->
  <section class="bg-white border-b border-steel-200">
    <div class="container-page py-4">
      <div class="flex flex-wrap items-center justify-center gap-4 text-xs text-steel-500">
        <span class="flex items-center gap-1.5"><span class="w-2 h-2 bg-green-500 rounded-full"></span> ISO 9001:2015 Certified</span>
        <span class="text-steel-300">|</span>
        <span class="flex items-center gap-1.5"><span class="w-2 h-2 bg-green-500 rounded-full"></span> ISO 45001 Certified</span>
        <span class="text-steel-300">|</span>
        <span class="flex items-center gap-1.5"><span class="w-2 h-2 bg-green-500 rounded-full"></span> ISO 14001 Certified</span>
        <span class="text-steel-300">|</span>
        <span>🏆 National High-Tech Enterprise (2022)</span>
        <span class="text-steel-300">|</span>
        <span>🏅 Science & Technology Little Giant (2023)</span>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-steel-50 border-b border-steel-200">
    <div class="container-page py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {stats.map((stat) => (
          <div class="group">
            <div class="text-3xl sm:text-4xl font-black text-brand-600 group-hover:scale-110 transition-transform duration-300">{stat.value}</div>
            <div class="mt-2 text-sm text-steel-500 font-medium">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose GRANGIN -->
  <section class="section-py bg-white">
    <div class="container-page">
      <h2 class="section-title">Why Choose <span class="text-brand-600">GRANGIN</span></h2>
      <p class="section-subtitle">
        China Custom Automation Parts Supplier Specializing in CNC Machining, Precision Manufacturing, Fast Delivery & OEM Solutions
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {qualityFeatures.map((feature) => (
          <div class="card-base p-8">
            <div class="text-4xl mb-4">{feature.icon}</div>
            <h3 class="text-lg font-bold text-steel-900 mb-3">{feature.title}</h3>
            <p class="text-sm text-steel-500 leading-relaxed">{feature.desc}</p>
          </div>
        ))}
      </div>
      <!-- Extra feature card -->
      <div class="mt-6 card-base p-8 text-center">
        <div class="text-4xl mb-3">💎</div>
        <h3 class="text-lg font-bold text-steel-900 mb-2">High-Value Solutions</h3>
        <p class="text-sm text-steel-500 leading-relaxed max-w-2xl mx-auto">Direct manufacturer with specialized technical strength. 25+ QC professionals enforcing rigorous quality control. Continuously refined production processes — custom cost efficiency for clients.</p>
      </div>
    </div>
  </section>

  <!-- Product Categories -->
  <section class="section-py bg-steel-50">
    <div class="container-page">
      <h2 class="section-title">Product <span class="text-brand-600">Categories</span></h2>
      <p class="section-subtitle">
        GRANGIN is a leading Chinese manufacturer of custom automation components. Fully supports customized drawings and 35+ materials.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
        {categories.map((cat) => (
          <a href={cat.href} class="flex items-center gap-3 p-3.5 bg-white rounded-lg border border-steel-200 hover:border-brand-300 hover:shadow-md transition-all group">
            <span class="text-xl shrink-0">{cat.icon}</span>
            <div>
              <span class="text-sm font-medium text-steel-700 group-hover:text-brand-600 transition-colors leading-tight">{cat.name}</span>
              <p class="text-[10px] text-steel-400 mt-0.5">Support Customized Size ›</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="section-py bg-white">
    <div class="container-page">
      <h2 class="section-title">Industrial <span class="text-brand-600">Applications</span></h2>
      <p class="section-subtitle">
        Reliable Power Transmission Components and Drive Solutions for diverse industries worldwide.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
        {industries.map((ind) => (
          <div class="card-base p-4 text-center group">
            <div class="text-2xl mb-2">{ind.icon}</div>
            <h4 class="text-xs font-bold text-steel-800">{ind.name}</h4>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section-py bg-dark-900 text-white">
    <div class="container-page">
      <h2 class="text-3xl font-black text-center mb-3">What Our <span class="text-brand-400">Customers Say</span></h2>
      <p class="text-steel-400 text-center max-w-xl mx-auto mb-10">
        Multi-awarded as "Integrity Enterprise" and "Grade-A Taxpayer" by authorities. Trusted partner for transmission components worldwide.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {testimonials.map((t) => (
          <div class="bg-dark-800 rounded-lg p-6 border border-dark-700">
            <div class="text-brand-400 text-2xl mb-3">"</div>
            <p class="text-sm text-steel-300 leading-relaxed mb-4">{t.text}</p>
            <div class="border-t border-dark-700 pt-3">
              <p class="text-sm font-semibold text-white">{t.name}</p>
              <p class="text-xs text-steel-500">{t.country}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- News -->
  <section class="section-py bg-steel-50">
    <div class="container-page">
      <h2 class="section-title">Latest <span class="text-brand-600">News</span></h2>
      <p class="section-subtitle">Industry insights and technical guides from our engineering team.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {blogPosts.map((post) => (
          <a href={post.href} class="card-base p-6 group">
            <p class="text-xs text-steel-400 mb-2">{post.date}</p>
            <h4 class="font-bold text-steel-800 group-hover:text-brand-600 transition-colors mb-2">{post.title}</h4>
            <span class="text-sm font-semibold text-brand-600">Read More →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-20 bg-brand-600 text-white">
    <div class="container-page text-center">
      <h2 class="text-3xl sm:text-4xl font-black mb-4">Ask the Experts</h2>
      <p class="text-brand-100 text-lg max-w-2xl mx-auto mb-8">
        12-hour response guarantee. Send us your drawings or specifications and we'll provide tailored solutions with 3D custom design blueprints.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="btn-white text-base px-8 py-3.5 font-bold">Get in Touch</a>
        <a href="mailto:info@ggn-gear.com" class="inline-flex items-center justify-center px-8 py-3.5 border-2 border-white text-white font-bold rounded-lg hover:bg-white/10 transition-colors text-base">info@ggn-gear.com</a>
      </div>
    </div>
  </section>

</Layout>
