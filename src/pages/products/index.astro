---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products', ({ data }) => data.published);
const categoryParam = Astro.url.searchParams.get('category');

const allCategories = [...new Set(allProducts.map(p => p.data.category))].sort();

const categoryOrder = [
  'Gear', 'Sprocket', 'Belt Pulley', 'Coupling',
  'Transmission Shaft', 'Lead Screw', 'Customized Parts',
  'Transmission Parts', 'Sheet Metal Components',
  'Gear Motor', 'Gearbox', 'AC Motor',
];

const filtered = categoryParam
  ? allProducts.filter(p => {
      const catSlug = p.data.category.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
      const paramSlug = categoryParam.toLowerCase();
      return catSlug === paramSlug || catSlug.includes(paramSlug) || paramSlug.includes(catSlug);
    })
  : allProducts;

const products = filtered.sort((a, b) => a.data.order - b.data.order || a.data.title.localeCompare(b.data.title));
---

<Layout title="Products" description="Browse GRANGIN's complete range of gears, sprockets, belt pulleys, gear motors & CNC machined parts. ISO 9001/45001/14001 certified manufacturer in Zhejiang, China.">
  
  <section class="bg-dark-900 text-white py-12 sm:py-16">
    <div class="container-page">
      <p class="text-brand-400 font-semibold text-sm uppercase tracking-wider mb-2">Product Catalog</p>
      <h1 class="text-3xl sm:text-4xl font-black">Gears, Sprockets & CNC Machined Parts</h1>
      <p class="mt-3 text-steel-400 max-w-2xl">
        Fully supports customized drawings and 35+ materials. Direct manufacturer with 25+ QC professionals. 25,000+ pieces monthly output.
      </p>
    </div>
  </section>

  <section class="section-py">
    <div class="container-page">
      <div class="flex flex-col lg:flex-row gap-8">
        <aside class="lg:w-56 shrink-0">
          <div class="sticky top-20">
            <h3 class="font-bold text-steel-800 mb-3 text-sm uppercase tracking-wider">Categories</h3>
            <ul class="space-y-0.5">
              <li>
                <a href="/woshidahuaidan/products/" 
                   class={`block px-3 py-2 rounded text-sm font-medium transition-colors ${!categoryParam ? 'bg-brand-600 text-white' : 'text-steel-600 hover:bg-steel-100 hover:text-brand-600'}`}>
                  All Products
                </a>
              </li>
              {categoryOrder.map((cat) => {
                const slug = cat.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
                const count = allProducts.filter(p => p.data.category === cat).length;
                const isActive = categoryParam === slug;
                return (
                  <li>
                    <a href={`/woshidahuaidan/products/?category=${slug}`}
                       class={`block px-3 py-2 rounded text-sm font-medium transition-colors ${isActive ? 'bg-brand-600 text-white' : 'text-steel-600 hover:bg-steel-100 hover:text-brand-600'}`}>
                      {cat}
                      {count > 0 && <span class={`ml-1.5 text-xs ${isActive ? 'text-brand-200' : 'text-steel-400'}`}>({count})</span>}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        </aside>

        <div class="flex-1 min-w-0">
          {categoryParam && (
            <div class="mb-6 flex items-center gap-3">
              <p class="text-sm text-steel-500">Showing <span class="font-semibold text-steel-700">{products.length}</span> products</p>
              <a href="/woshidahuaidan/products/" class="text-xs text-brand-600 hover:text-brand-700 font-medium">Clear filter</a>
            </div>
          )}

          {products.length === 0 ? (
            <div class="text-center py-20">
              <div class="text-5xl mb-4">📦</div>
              <h3 class="text-xl font-bold text-steel-700 mb-2">No products in this category yet</h3>
              <p class="text-steel-500 mb-4">We're adding more products. Contact us for custom requirements.</p>
              <a href="/woshidahuaidan/contact/" class="btn-primary">Contact Us</a>
            </div>
          ) : (
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
              {products.map((product) => (
                <a href={`/woshidahuaidan/products/${product.id}/`} class="card-base group flex flex-col">
                  <div class="aspect-[4/3] bg-steel-100 flex items-center justify-center">
                    {product.data.image ? (
                      <img src={product.data.image} alt={product.data.title} class="w-full h-full object-cover" />
                    ) : (
                      <div class="text-center p-4">
                        <div class="text-5xl mb-2">⚙️</div>
                        <span class="tag tag-red">{product.data.category}</span>
                      </div>
                    )}
                  </div>
                  <div class="p-4 flex-1 flex flex-col">
                    <span class="text-xs font-semibold text-brand-600 uppercase tracking-wide mb-1">{product.data.category}</span>
                    <h3 class="font-bold text-steel-900 group-hover:text-brand-600 transition-colors mb-2 line-clamp-2">{product.data.title}</h3>
                    <p class="text-sm text-steel-500 leading-relaxed line-clamp-2 mb-3 flex-1">{product.data.excerpt}</p>
                    <div class="flex items-center justify-between pt-3 border-t border-steel-100">
                      <span class="stock-in">In Stock</span>
                      <span class="text-sm font-semibold text-brand-600 group-hover:text-brand-700 transition-colors">Quick Quote →</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

</Layout>
