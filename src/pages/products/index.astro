---
// ============================================================
// products/index.astro — Product listing with category filter
// ============================================================
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products', ({ data }) => data.published);
const categoryParam = Astro.url.searchParams.get('category');

// All unique categories from products
const allCategories = [...new Set(allProducts.map(p => p.data.category))].sort();

// Explicit category display order
const categoryOrder = [
  'Worm Gearbox', 'Helical Gearbox', 'Bevel Gearbox', 'Industrial Gearbox',
  'Variator', 'Gear Motor', 'AC Motor', 'Gear', 'Sprocket',
  'Belt Pulley', 'Coupling', 'Sheet Metal',
];

// Filter if category specified
const filtered = categoryParam
  ? allProducts.filter(p => p.data.category.toLowerCase().replace(/\s+/g, '-').includes(categoryParam.toLowerCase().replace(/-/g, ' ')) || p.data.category === categoryParam)
  : allProducts;

// Sort by order then title
const products = filtered.sort((a, b) => a.data.order - b.data.order || a.data.title.localeCompare(b.data.title));
---

<Layout title="Products" description="Browse Guangjin's complete range of industrial gearboxes, gear motors, and power transmission components. 150,000+ products in stock.">
  
  <!-- Page Header -->
  <section class="bg-dark-900 text-white py-12 sm:py-16">
    <div class="container-page">
      <p class="text-brand-400 font-semibold text-sm uppercase tracking-wider mb-2">Product Catalog</p>
      <h1 class="text-3xl sm:text-4xl font-black">Industrial Gearboxes & Power Transmission</h1>
      <p class="mt-3 text-steel-400 max-w-2xl">
        China's professional power transmission manufacturer. We offer customized product services and free samples. Most products are mass-produced and kept in stock, ready for immediate shipment.
      </p>
      <div class="flex flex-wrap gap-3 mt-6">
        <span class="flex items-center gap-1 text-sm text-steel-300">
          <span class="text-brand-400 font-bold">{allProducts.length}</span> Products
        </span>
        <span class="text-steel-600">|</span>
        <span class="text-sm text-steel-300">ANSI, ISO Standards</span>
        <span class="text-steel-600">|</span>
        <span class="text-sm text-steel-300">Satisfaction Guaranteed</span>
      </div>
    </div>
  </section>

  <!-- Content Area -->
  <section class="section-py">
    <div class="container-page">
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Sidebar: Category Filter -->
        <aside class="lg:w-56 shrink-0">
          <div class="sticky top-20">
            <h3 class="font-bold text-steel-800 mb-3 text-sm uppercase tracking-wider">Categories</h3>
            <ul class="space-y-0.5">
              <li>
                <a href="/woshidahuaidan/products/" 
                   class={`block px-3 py-2 rounded text-sm font-medium transition-colors ${!categoryParam ? 'bg-brand-600 text-white' : 'text-steel-600 hover:bg-steel-100 hover:text-brand-600'}`}>
                  All Products
                </a>
              </li>
              {categoryOrder.map((cat) => {
                const slug = cat.toLowerCase().replace(/\s+/g, '-');
                const count = allProducts.filter(p => p.data.category === cat).length;
                if (count === 0) return null;
                const isActive = categoryParam === slug;
                return (
                  <li>
                    <a href={`/products/?category=${slug}`}
                       class={`block px-3 py-2 rounded text-sm font-medium transition-colors ${isActive ? 'bg-brand-600 text-white' : 'text-steel-600 hover:bg-steel-100 hover:text-brand-600'}`}>
                      {cat}
                      <span class={`ml-1.5 text-xs ${isActive ? 'text-brand-200' : 'text-steel-400'}`}>({count})</span>
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        </aside>

        <!-- Main: Product Grid -->
        <div class="flex-1 min-w-0">
          {categoryParam && (
            <div class="mb-6 flex items-center gap-3">
              <p class="text-sm text-steel-500">
                Showing <span class="font-semibold text-steel-700">{products.length}</span> products
                {categoryParam && <> in <span class="tag tag-red ml-1">{categoryParam.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())}</span></>}
              </p>
              <a href="/woshidahuaidan/products/" class="text-xs text-brand-600 hover:text-brand-700 font-medium">Clear filter</a>
            </div>
          )}

          {products.length === 0 ? (
            <div class="text-center py-20">
              <div class="text-5xl mb-4">📦</div>
              <h3 class="text-xl font-bold text-steel-700 mb-2">No products found</h3>
              <p class="text-steel-500 mb-4">Try a different category or browse all products.</p>
              <a href="/woshidahuaidan/products/" class="btn-primary">View All Products</a>
            </div>
          ) : (
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
              {products.map((product) => (
                <a href={`/products/${product.id}/`} class="card-base group flex flex-col">
                  <!-- Image -->
                  <div class="aspect-[4/3] bg-steel-100 flex items-center justify-center">
                    {product.data.image ? (
                      <img src={product.data.image} alt={product.data.title} class="w-full h-full object-cover" />
                    ) : (
                      <div class="text-center p-4">
                        <div class="text-5xl mb-2">⚙️</div>
                        <span class="tag tag-red">{product.data.category}</span>
                      </div>
                    )}
                  </div>
                  <!-- Info -->
                  <div class="p-4 flex-1 flex flex-col">
                    <span class="text-xs font-semibold text-brand-600 uppercase tracking-wide mb-1">{product.data.category}</span>
                    <h3 class="font-bold text-steel-900 group-hover:text-brand-600 transition-colors mb-2 line-clamp-2">{product.data.title}</h3>
                    <p class="text-sm text-steel-500 leading-relaxed line-clamp-2 mb-3 flex-1">{product.data.excerpt}</p>
                    
                    {product.data.specs && product.data.specs.length > 0 && (
                      <div class="flex flex-wrap gap-1.5 mb-3">
                        {product.data.specs.slice(0, 3).map((spec) => (
                          <span class="text-[10px] bg-steel-100 text-steel-600 px-2 py-0.5 rounded-full font-medium">{spec.name}: {spec.value}</span>
                        ))}
                      </div>
                    )}
                    
                    <div class="flex items-center justify-between pt-3 border-t border-steel-100">
                      <span class="stock-in">In Stock</span>
                      <span class="text-sm font-semibold text-brand-600 group-hover:text-brand-700 transition-colors">
                        Quick Quote →
                      </span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          )}

          <!-- Pagination (placeholder) -->
          {products.length > 12 && (
            <div class="flex justify-center gap-2 mt-10">
              <span class="px-4 py-2 bg-brand-600 text-white rounded text-sm font-semibold">1</span>
              <span class="px-4 py-2 bg-steel-100 text-steel-600 rounded text-sm font-semibold hover:bg-steel-200 cursor-pointer">2</span>
              <span class="px-4 py-2 bg-steel-100 text-steel-600 rounded text-sm font-semibold hover:bg-steel-200 cursor-pointer">3</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

</Layout>
