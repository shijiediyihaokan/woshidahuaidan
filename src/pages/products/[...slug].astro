---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

interface Props {
  product: any;
}

const { product } = Astro.props;
const { title, image, excerpt, category, features, specs } = product.data;
---

<Layout title={title} description={excerpt}>
  <section class="py-12 sm:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-steel-500 mb-8">
        <a href="/" class="hover:text-brand-600">Home</a>
        <span>/</span>
        <a href="/products/" class="hover:text-brand-600">Products</a>
        <span>/</span>
        <a href={`/products/?category=${encodeURIComponent(category)}`} class="hover:text-brand-600">{category}</a>
        <span>/</span>
        <span class="text-steel-800 font-medium truncate">{title}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <!-- Image -->
        <div>
          <div class="bg-steel-100 rounded-xl overflow-hidden aspect-[4/3]">
            {image ? (
              <img src={image} alt={title} class="w-full h-full object-cover" />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-steel-400">
                <svg class="w-24 h-24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </div>
            )}
          </div>
        </div>

        <!-- Info -->
        <div>
          <span class="text-xs font-semibold text-brand-600 uppercase tracking-wide">{category}</span>
          <h1 class="mt-2 text-3xl font-bold text-steel-900">{title}</h1>
          <p class="mt-4 text-steel-600 leading-relaxed">{excerpt}</p>

          <!-- Features -->
          {features.length > 0 && (
            <div class="mt-6">
              <h3 class="text-lg font-semibold text-steel-900 mb-3">Key Features</h3>
              <ul class="space-y-2">
                {features.map((f: string) => (
                  <li class="flex items-start gap-2 text-sm text-steel-600">
                    <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- CTA -->
          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <a
              href="/contact/"
              class="inline-flex items-center justify-center px-6 py-3 bg-brand-600 text-white font-semibold rounded-lg hover:bg-brand-700 transition-colors shadow-sm"
            >
              Request Quote
            </a>
            <a
              href="/products/"
              class="inline-flex items-center justify-center px-6 py-3 border border-steel-300 text-steel-700 font-semibold rounded-lg hover:bg-steel-50 transition-colors"
            >
              Back to Products
            </a>
          </div>
        </div>
      </div>

      <!-- Specs Table -->
      {specs.length > 0 && (
        <div class="mt-14">
          <h2 class="text-2xl font-bold text-steel-900 mb-6">Technical Specifications</h2>
          <div class="overflow-x-auto rounded-xl border border-steel-200">
            <table class="w-full">
              <thead>
                <tr class="bg-steel-50">
                  <th class="text-left px-6 py-3 text-sm font-semibold text-steel-700">Parameter</th>
                  <th class="text-left px-6 py-3 text-sm font-semibold text-steel-700">Value</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-steel-200">
                {specs.map((spec: { name: string; value: string }) => (
                  <tr class="hover:bg-steel-50/50">
                    <td class="px-6 py-3 text-sm font-medium text-steel-700">{spec.name}</td>
                    <td class="px-6 py-3 text-sm text-steel-600">{spec.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}
    </div>
  </section>
</Layout>
