---
// ============================================================
// knowledge-center/[category].astro — Category-filtered articles
// ============================================================
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const categories = ['Product Knowledge', 'Selection Guide', 'Technical Guide', 'Industry News', 'Company News'];
  return categories.map((cat) => ({
    params: { category: cat.toLowerCase().replace(/\s+/g, '-') },
    props: { categoryName: cat },
  }));
}

const { categoryName } = Astro.props as { categoryName: string };

const articles = await getCollection('news', ({ data }) =>
  data.published && data.category === categoryName
);
const sortedArticles = articles.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Build sidebar data
const allCategories = ['Product Knowledge', 'Selection Guide', 'Technical Guide', 'Industry News', 'Company News'];
function categorySlug(cat: string): string {
  return cat.toLowerCase().replace(/\s+/g, '-');
}
// Get counts for all categories
const allArticles = await getCollection('news', ({ data }) => data.published);
const catCounts: Record<string, number> = {};
allCategories.forEach(c => {
  catCounts[c] = allArticles.filter(a => a.data.category === c).length;
});

const pageDescription = `${categoryName} articles — expert guides and industry insights on gears, gearboxes, CNC machining, and power transmission.`;
const pageKeywords = `${categoryName.toLowerCase()}, gear manufacturing, industrial transmission, GRANGIN blog`;
---

<Layout title={`${categoryName} — Knowledge Center`} description={pageDescription} keywords={pageKeywords} pageType="blog">
  
  <section class="bg-dark-900 text-white py-12 sm:py-16">
    <div class="container-page">
      <p class="text-brand-400 font-semibold text-sm uppercase tracking-wider mb-2">
        <a href="/knowledge-center/" class="hover:text-brand-300 transition-colors">Knowledge Center</a> / {categoryName}
      </p>
      <h1 class="text-3xl sm:text-4xl font-black">{categoryName}</h1>
      <p class="mt-3 text-steel-400 max-w-2xl">
        {sortedArticles.length} article{sortedArticles.length !== 1 ? 's' : ''} in this category
      </p>
    </div>
  </section>

  <section class="section-py bg-white">
    <div class="container-page">
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Category sidebar -->
        <aside class="lg:w-52 shrink-0">
          <h3 class="font-bold text-steel-800 mb-3 text-sm uppercase tracking-wider">Categories</h3>
          <ul class="space-y-0.5">
            <li>
              <a href="/knowledge-center/" class="block px-3 py-2 rounded text-sm hover:bg-brand-50 hover:text-brand-600 transition-colors text-steel-700 font-medium">
                All Articles ({allArticles.length})
              </a>
            </li>
            {allCategories.map((cat) => (
              <li>
                <a href={`/knowledge-center/${categorySlug(cat)}/`} class={`block px-3 py-2 rounded text-sm hover:bg-brand-50 hover:text-brand-600 transition-colors ${cat === categoryName ? 'bg-brand-600 text-white' : (catCounts[cat] ? 'text-steel-700 font-medium' : 'text-steel-400')}`}>
                  {cat} <span class="text-xs opacity-70">({catCounts[cat] || 0})</span>
                </a>
              </li>
            ))}
          </ul>
        </aside>

        <!-- Article grid -->
        <div class="flex-1 min-w-0">
          {sortedArticles.length === 0 ? (
            <div class="text-center py-16">
              <p class="text-steel-400 text-lg mb-4">No articles in this category yet.</p>
              <a href="/knowledge-center/" class="btn-outline text-sm">← View All Articles</a>
            </div>
          ) : (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {sortedArticles.map((article) => (
                <article class="card-base group">
                  <div class="aspect-[16/9] bg-steel-100 flex items-center justify-center overflow-hidden">
                    {article.data.image ? (
                      <img src={article.data.image} alt={article.data.title} class="w-full h-full object-cover" loading="lazy" />
                    ) : (
                      <div class="text-center p-4">
                        <div class="text-4xl mb-2">📰</div>
                        <span class="tag tag-red">{article.data.category}</span>
                      </div>
                    )}
                  </div>
                  <div class="p-5">
                    <span class="tag tag-red text-xs mb-2">{article.data.category}</span>
                    <p class="text-xs text-steel-400 mt-2 mb-2">
                      {new Date(article.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </p>
                    <h2 class="font-bold text-steel-900 group-hover:text-brand-600 transition-colors mb-2 text-lg line-clamp-2">
                      <a href={`/news/${article.data.slug || article.id}/`}>{article.data.title}</a>
                    </h2>
                    <p class="text-sm text-steel-500 leading-relaxed line-clamp-3 mb-3">{article.data.excerpt}</p>
                    <a href={`/news/${article.data.slug || article.id}/`} class="text-sm font-semibold text-brand-600 group-hover:text-brand-700 transition-colors">
                      Read More →
                    </a>
                  </div>
                </article>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

</Layout>
