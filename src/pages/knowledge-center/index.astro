---
// ============================================================
// knowledge-center/index.astro — Knowledge Center: all articles
// ============================================================
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('news', ({ data }) => data.published);
const sortedArticles = articles.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categories = ['Product Knowledge', 'Selection Guide', 'Technical Guide', 'Industry News', 'Company News'];
const catCounts: Record<string, number> = {};
categories.forEach(c => {
  catCounts[c] = articles.filter(a => a.data.category === c).length;
});

function categorySlug(cat: string): string {
  return cat.toLowerCase().replace(/\s+/g, '-');
}

const pageDescription = 'Expert guides and industry insights on gears, sprockets, gearboxes, CNC machining, and power transmission components.';
const pageKeywords = 'gearbox blog, gear manufacturing guides, CNC machining tips, worm gearbox selection, gear motor manufacturers, industrial transmission blog';
---

<Layout title="Knowledge Center" description={pageDescription} keywords={pageKeywords} pageType="blog">
  
  <section class="bg-dark-900 text-white py-12 sm:py-16">
    <div class="container-page">
      <p class="text-brand-400 font-semibold text-sm uppercase tracking-wider mb-2">Knowledge Center</p>
      <h1 class="text-3xl sm:text-4xl font-black">Industry Insights & Expert Guides</h1>
      <p class="mt-3 text-steel-400 max-w-2xl">
        Stay informed with the latest technical guides, industry reports, and manufacturing insights from the GRANGIN engineering team.
      </p>
    </div>
  </section>

  <section class="section-py bg-white">
    <div class="container-page">
      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Category sidebar -->
        <aside class="lg:w-52 shrink-0">
          <h3 class="font-bold text-steel-800 mb-3 text-sm uppercase tracking-wider">Categories</h3>
          <ul class="space-y-0.5">
            <li>
              <a href="/knowledge-center/" class="block px-3 py-2 rounded text-sm font-medium bg-brand-600 text-white">
                All Articles ({articles.length})
              </a>
            </li>
            {categories.map((cat) => (
              <li>
                <a href={`/knowledge-center/${categorySlug(cat)}/`} class={`block px-3 py-2 rounded text-sm hover:bg-brand-50 hover:text-brand-600 transition-colors ${catCounts[cat] ? 'text-steel-700 font-medium' : 'text-steel-400'}`}>
                  {cat} <span class="text-xs text-steel-400">({catCounts[cat] || 0})</span>
                </a>
              </li>
            ))}
          </ul>
        </aside>

        <!-- Article grid -->
        <div class="flex-1 min-w-0">
          {sortedArticles.length === 0 ? (
            <p class="text-steel-400 text-center py-16">No articles yet. Check back soon.</p>
          ) : (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {sortedArticles.map((article) => (
                <article class="card-base group">
                  <div class="aspect-[16/9] bg-steel-100 flex items-center justify-center overflow-hidden">
                    {article.data.image ? (
                      <img src={article.data.image} alt={article.data.title} class="w-full h-full object-cover" loading="lazy" />
                    ) : (
                      <div class="text-center p-4">
                        <div class="text-4xl mb-2">📰</div>
                        <span class="tag tag-red">{article.data.category}</span>
                      </div>
                    )}
                  </div>
                  <div class="p-5">
                    <span class="tag tag-red text-xs mb-2">{article.data.category}</span>
                    <p class="text-xs text-steel-400 mt-2 mb-2">
                      {new Date(article.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </p>
                    <h2 class="font-bold text-steel-900 group-hover:text-brand-600 transition-colors mb-2 text-lg line-clamp-2">
                      <a href={`/news/${article.data.slug || article.id}/`}>{article.data.title}</a>
                    </h2>
                    <p class="text-sm text-steel-500 leading-relaxed line-clamp-3 mb-3">{article.data.excerpt}</p>
                    <a href={`/news/${article.data.slug || article.id}/`} class="text-sm font-semibold text-brand-600 group-hover:text-brand-700 transition-colors">
                      Read More →
                    </a>
                  </div>
                </article>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

</Layout>
