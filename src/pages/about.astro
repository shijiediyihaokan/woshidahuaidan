---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us" description="Zhejiang Guangjin Intelligent Technology Co., Ltd. (Brand: GRANGIN) — 20+ years focus on transmission industry. National High-Tech Enterprise, ISO 9001/45001/14001 certified. Located in Shengzhou, Zhejiang, China.">
  
  <section class="bg-dark-900 text-white py-12 sm:py-16">
    <div class="container-page">
      <p class="text-brand-400 font-semibold text-sm uppercase tracking-wider mb-2">About GRANGIN</p>
      <h1 class="text-3xl sm:text-4xl font-black">20+ Years Focus on Transmission Industry</h1>
    </div>
  </section>

  <section class="section-py bg-white">
    <div class="container-page">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="text-3xl font-bold text-steel-900 mb-4">Zhejiang Guangjin Intelligent Technology Co., Ltd.</h2>
          <p class="text-steel-500 leading-relaxed mb-4">
            Brand <strong class="text-brand-600">GRANGIN</strong>, headquartered at No. 862, Sanjie High-tech Park, Shengzhou City, Zhejiang Province, China. We specialize in transmission components — gears, sprockets, belt pulleys, gear motors, and CNC machined parts.
          </p>
          <p class="text-steel-500 leading-relaxed mb-4">
            With over 20 years dedicated to the transmission industry, GRANGIN has grown into a recognized leader. We are a <strong>National High-Tech Enterprise</strong> (2022) and a <strong>"Science and Technology Little Giant"</strong> (2023). We have repeatedly earned "Integrity Enterprise" and "Grade-A Taxpayer" designations.
          </p>
          <p class="text-steel-500 leading-relaxed mb-6">
            Certified to ISO 9001, ISO 45001, and ISO 14001 quality standards, we integrate trading with in-house manufacturing supported by advanced CNC machinery and a 2,000 m² material preparation warehouse.
          </p>
          
          <div class="grid grid-cols-3 gap-4">
            <div class="text-center p-4 bg-brand-50 rounded-lg">
              <div class="text-2xl font-black text-brand-600">10K+</div>
              <div class="text-xs text-steel-500 mt-1">Factory Area m²</div>
            </div>
            <div class="text-center p-4 bg-brand-50 rounded-lg">
              <div class="text-2xl font-black text-brand-600">25K+</div>
              <div class="text-xs text-steel-500 mt-1">Monthly Output</div>
            </div>
            <div class="text-center p-4 bg-brand-50 rounded-lg">
              <div class="text-2xl font-black text-brand-600">25+</div>
              <div class="text-xs text-steel-500 mt-1">QC Professionals</div>
            </div>
          </div>
        </div>
        
        <div class="aspect-[4/3] bg-steel-100 rounded-lg flex items-center justify-center">
          <div class="text-center p-8">
            <div class="text-7xl mb-3">🏭</div>
            <p class="text-steel-400 text-sm">No. 862, Sanjie High-tech Park, Shengzhou, Zhejiang</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose -->
  <section class="section-py bg-steel-50">
    <div class="container-page">
      <h2 class="section-title">Why Choose <span class="text-brand-600">GRANGIN</span></h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-10">
        <div class="card-base p-6">
          <div class="text-4xl mb-3">🎯</div>
          <h3 class="font-bold text-steel-900 mb-2">Expert Customization</h3>
          <p class="text-sm text-steel-500">Chief Engineer with 30+ years in automation. Average engineering tenure 15+ years. 3D custom design blueprints.</p>
        </div>
        <div class="card-base p-6">
          <div class="text-4xl mb-3">⏱️</div>
          <h3 class="font-bold text-steel-900 mb-2">Reliable Service</h3>
          <p class="text-sm text-steel-500">12-hour response guarantee. Prompt quotation and customized solution feedback.</p>
        </div>
        <div class="card-base p-6">
          <div class="text-4xl mb-3">🚀</div>
          <h3 class="font-bold text-steel-900 mb-2">Rapid Delivery</h3>
          <p class="text-sm text-steel-500">Priority fast-track for urgent orders. Optimized production scheduling coordination.</p>
        </div>
        <div class="card-base p-6">
          <div class="text-4xl mb-3">💎</div>
          <h3 class="font-bold text-steel-900 mb-2">High-Value Solutions</h3>
          <p class="text-sm text-steel-500">25+ QC professionals. Three manual inspections per product. Export-grade packaging.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="section-py bg-white">
    <div class="container-page text-center">
      <h2 class="section-title">Quality <span class="text-brand-600">Certifications</span></h2>
      <div class="flex flex-wrap justify-center gap-6 mt-6">
        <div class="bg-white rounded-lg border border-steel-200 px-8 py-6 shadow-sm">
          <div class="text-3xl font-black text-brand-600">ISO 9001</div>
          <p class="text-xs text-steel-500 mt-1">Quality Management</p>
        </div>
        <div class="bg-white rounded-lg border border-steel-200 px-8 py-6 shadow-sm">
          <div class="text-3xl font-black text-brand-600">ISO 45001</div>
          <p class="text-xs text-steel-500 mt-1">Occupational Health & Safety</p>
        </div>
        <div class="bg-white rounded-lg border border-steel-200 px-8 py-6 shadow-sm">
          <div class="text-3xl font-black text-brand-600">ISO 14001</div>
          <p class="text-xs text-steel-500 mt-1">Environmental Management</p>
        </div>
        <div class="bg-white rounded-lg border border-brand-200 px-8 py-6 shadow-sm bg-brand-50">
          <div class="text-xl font-black text-brand-600">🏆 National</div>
          <p class="text-xs text-steel-500 mt-1">High-Tech Enterprise 2022</p>
        </div>
        <div class="bg-white rounded-lg border border-brand-200 px-8 py-6 shadow-sm bg-brand-50">
          <div class="text-xl font-black text-brand-600">🏅 Little</div>
          <p class="text-xs text-steel-500 mt-1">Science & Tech Giant 2023</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-20 bg-brand-600 text-white text-center">
    <div class="container-page">
      <h2 class="text-3xl font-black mb-4">Work with GRANGIN</h2>
      <p class="text-brand-100 text-lg max-w-xl mx-auto mb-8">Fully supports customized drawings and 35+ materials. Contact us today.</p>
      <a href="/contact/" class="btn-white text-base px-8 py-3.5 font-bold">Contact Us</a>
    </div>
  </section>

</Layout>
