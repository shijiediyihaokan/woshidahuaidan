---
// Redirect /news/ → /knowledge-center/
import Layout from '../../layouts/Layout.astro';
const redirectUrl = new URL('/knowledge-center/', Astro.site).href;
---
<Layout title="Knowledge Center">
  <meta http-equiv="refresh" content={`0;url=${redirectUrl}`} />
  <link rel="canonical" href={redirectUrl} />
  <section class="bg-dark-900 text-white py-20">
    <div class="container-page text-center">
      <h1 class="text-3xl font-black mb-4">Knowledge Center has moved</h1>
      <p class="text-steel-400 mb-6">Redirecting to our new Knowledge Center...</p>
      <a href="/knowledge-center/" class="btn-primary">Go to Knowledge Center</a>
    </div>
  </section>
</Layout>
