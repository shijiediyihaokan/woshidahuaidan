---
// ============================================================
// news/index.astro — Blog/News for content marketing SEO
// ============================================================
import Layout from '../../layouts/Layout.astro';

const articles = [
  {
    title: 'Are Worm Gearboxes Self-Locking?',
    date: '2026-06-05',
    excerpt: 'Many customers ask whether a worm gearbox can stop reverse rotation by itself. The answer is: sometimes yes, but it depends on several factors including the lead angle, coefficient of friction, and lubrication condition.',
    slug: 'are-worm-gearboxes-self-locking',
    category: 'Technical Guide',
  },
  {
    title: 'Top 10 China Worm Gear Motor Manufacturers In 2026',
    date: '2026-05-19',
    excerpt: 'The global demand for compact industrial transmission systems continues to grow. We analyze the leading worm gear motor manufacturers in China, evaluating their capabilities, certifications, and market presence.',
    slug: 'top-10-worm-gear-motor-manufacturers',
    category: 'Industry Report',
  },
  {
    title: 'Top 10 China AC Gear Motor Manufacturers In 2026',
    date: '2026-05-19',
    excerpt: 'The global industrial automation market is expanding rapidly, driving strong demand for reliable AC gear motors. Here is our analysis of the top manufacturers in China.',
    slug: 'top-10-ac-gear-motor-manufacturers',
    category: 'Industry Report',
  },
  {
    title: 'How To Select The Right Spur Gear For Your Application',
    date: '2026-04-28',
    excerpt: 'Choosing the correct spur gear involves understanding module, pressure angle, face width, and material selection. This guide walks you through the key parameters and selection criteria.',
    slug: 'select-right-spur-gear',
    category: 'Technical Guide',
  },
  {
    title: 'Understanding CNC Machining Tolerances for Custom Parts',
    date: '2026-04-15',
    excerpt: 'When ordering custom CNC machined parts, specifying the right tolerances is critical for both functionality and cost. Learn about standard tolerance grades and how to specify them correctly.',
    slug: 'cnc-machining-tolerances',
    category: 'Technical Guide',
  },
];

const pageDescription = 'Expert guides and industry insights on gears, sprockets, gearboxes, CNC machining, and power transmission components. Stay informed with GRANGIN technical blog.';
const pageKeywords = 'gearbox blog, gear manufacturing guides, CNC machining tips, worm gearbox selection, gear motor manufacturers, industrial transmission blog';
---

<Layout title="News & Guides" description={pageDescription} keywords={pageKeywords} pageType="blog">
  
  <section class="bg-dark-900 text-white py-12 sm:py-16">
    <div class="container-page">
      <p class="text-brand-400 font-semibold text-sm uppercase tracking-wider mb-2">News & Technical Guides</p>
      <h1 class="text-3xl sm:text-4xl font-black">Industry Insights & Expert Guides</h1>
      <p class="mt-3 text-steel-400 max-w-2xl">
        Stay informed with the latest technical guides, industry reports, and manufacturing insights from the GRANGIN engineering team.
      </p>
    </div>
  </section>

  <section class="section-py bg-white">
    <div class="container-page">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {articles.map((article) => (
          <article class="card-base group">
            <div class="aspect-[16/9] bg-steel-100 flex items-center justify-center">
              <div class="text-center p-4">
                <div class="text-4xl mb-2">📰</div>
                <span class="tag tag-red">{article.category}</span>
              </div>
            </div>
            <div class="p-5">
              <p class="text-xs text-steel-400 mb-2">
                {new Date(article.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
              <h2 class="font-bold text-steel-900 group-hover:text-brand-600 transition-colors mb-2 text-lg">
                <a href={`/woshidahuaidan/news/${article.slug}/`}>{article.title}</a>
              </h2>
              <p class="text-sm text-steel-500 leading-relaxed line-clamp-3 mb-3">{article.excerpt}</p>
              <a href={`/woshidahuaidan/news/${article.slug}/`} class="text-sm font-semibold text-brand-600 group-hover:text-brand-700 transition-colors">
                Read More →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</Layout>
