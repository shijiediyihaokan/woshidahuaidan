---
// ============================================================
// contact.astro — CTS-style Contact page for Guangjin Gear
// ============================================================
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us" description="Contact Zhejiang Guangjin for industrial gearbox inquiries. Get a quote, request samples, or speak with our engineering team. Fast response within 24 hours.">
  
  <!-- Page Header -->
  <section class="bg-dark-900 text-white py-12 sm:py-16">
    <div class="container-page">
      <p class="text-brand-400 font-semibold text-sm uppercase tracking-wider mb-2">Get in Touch</p>
      <h1 class="text-3xl sm:text-4xl font-black">Contact Guangjin</h1>
      <p class="mt-3 text-steel-400 max-w-2xl">
        Having trouble finding the product you need? Send us your requirements and we'll quickly respond with tailored solutions. We're eager to hear from you!
      </p>
    </div>
  </section>

  <!-- Contact Form + Info -->
  <section class="section-py bg-white">
    <div class="container-page">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        
        <!-- Contact Form -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-steel-900 mb-6">Send Us a Message</h2>
          
          <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-medium text-steel-700 mb-1.5">Name *</label>
                <input type="text" id="name" name="name" required
                  class="w-full px-4 py-2.5 border border-steel-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-shadow"
                  placeholder="Your name">
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-steel-700 mb-1.5">Email *</label>
                <input type="email" id="email" name="email" required
                  class="w-full px-4 py-2.5 border border-steel-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-shadow"
                  placeholder="your@email.com">
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="company" class="block text-sm font-medium text-steel-700 mb-1.5">Company</label>
                <input type="text" id="company" name="company"
                  class="w-full px-4 py-2.5 border border-steel-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-shadow"
                  placeholder="Your company">
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-steel-700 mb-1.5">Phone</label>
                <input type="tel" id="phone" name="phone"
                  class="w-full px-4 py-2.5 border border-steel-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-shadow"
                  placeholder="+86-xxx-xxxx">
              </div>
            </div>

            <div>
              <label for="product" class="block text-sm font-medium text-steel-700 mb-1.5">Product Interest</label>
              <select id="product" name="product"
                class="w-full px-4 py-2.5 border border-steel-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-shadow bg-white">
                <option value="">Select a product category</option>
                <option value="Worm Gearbox">Worm Gearbox</option>
                <option value="Helical Gearbox">Helical Gearbox</option>
                <option value="Bevel Gearbox">Bevel Gearbox</option>
                <option value="Industrial Gearbox">Industrial Gearbox</option>
                <option value="Variator">Variator</option>
                <option value="Gear Motor">Gear Motor</option>
                <option value="AC Motor">AC Motor</option>
                <option value="Gear">Gears & Racks</option>
                <option value="Sprocket">Sprockets</option>
                <option value="Belt Pulley">Belt Pulleys</option>
                <option value="Coupling">Couplings</option>
                <option value="Other">Other / Custom</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-steel-700 mb-1.5">Message *</label>
              <textarea id="message" name="message" rows="6" required
                class="w-full px-4 py-2.5 border border-steel-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-shadow resize-y"
                placeholder="Tell us about your requirements — product specifications, quantity, application, etc."></textarea>
            </div>

            <button type="submit" class="btn-primary text-base px-8 py-3.5 w-full sm:w-auto">
              Send Message →
            </button>
            
            <p class="text-xs text-steel-400 mt-2">
              We respect your privacy. Your information will never be shared.
            </p>
          </form>
        </div>

        <!-- Contact Info Sidebar -->
        <div>
          <h2 class="text-2xl font-bold text-steel-900 mb-6">Contact Info</h2>
          
          <div class="space-y-6">
            <!-- Company Card -->
            <div class="bg-steel-50 rounded-lg p-5">
              <h3 class="font-bold text-steel-800 mb-3">Zhejiang Guangjin Intelligent Technology Co., Ltd.</h3>
              <p class="text-sm text-steel-500 leading-relaxed">
                China's professional power transmission manufacturer. We offer customized product services and free samples to meet customer needs.
              </p>
            </div>

            <!-- Contact Details -->
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 bg-brand-100 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-steel-800">Address</p>
                  <p class="text-sm text-steel-500">Zhejiang Province, China</p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-10 h-10 bg-brand-100 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-steel-800">Email</p>
                  <a href="mailto:info@ggn-gear.com" class="text-sm text-brand-600 hover:text-brand-700 font-medium">info@ggn-gear.com</a>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-10 h-10 bg-brand-100 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-semibold text-steel-800">Phone</p>
                  <p class="text-sm text-steel-500">+86-577-xxxxxxxx</p>
                </div>
              </div>
            </div>

            <!-- Business Hours -->
            <div class="bg-brand-50 rounded-lg p-5 border border-brand-100">
              <h4 class="font-bold text-brand-800 mb-2 text-sm">Business Hours</h4>
              <ul class="space-y-1.5 text-sm text-steel-600">
                <li class="flex justify-between"><span>Mon - Fri</span><span class="font-medium">8:00 - 18:00</span></li>
                <li class="flex justify-between"><span>Saturday</span><span class="font-medium">9:00 - 16:00</span></li>
                <li class="flex justify-between"><span>Sunday</span><span class="font-medium text-steel-400">Closed</span></li>
              </ul>
              <p class="text-xs text-steel-400 mt-3">China Standard Time (UTC+8)</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map placeholder -->
  <section class="bg-steel-100">
    <div class="aspect-[21/9] flex items-center justify-center">
      <div class="text-center p-8">
        <div class="text-6xl mb-3">🗺️</div>
        <p class="text-steel-400 font-medium">Zhejiang Province, China</p>
        <p class="text-xs text-steel-400 mt-1">Map will display here</p>
      </div>
    </div>
  </section>

</Layout>
