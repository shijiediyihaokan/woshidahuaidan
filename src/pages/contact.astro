---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title="Contact Us" description="Get in touch with Zhejiang Guangjin for industrial gearbox inquiries, custom orders, and technical questions.">
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-steel-900">Contact Us</h1>
        <p class="mt-4 text-steel-500 text-lg max-w-2xl mx-auto">
          Have a question or need a quote? Fill out the form below and our team will get back to you within 24 hours.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Form -->
        <div class="lg:col-span-2">
          <ContactForm />
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <div class="bg-gradient-to-br from-brand-50 to-steel-50 rounded-xl p-6">
            <h3 class="font-bold text-steel-900 mb-4">Contact Information</h3>
            <ul class="space-y-4 text-sm">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                <div>
                  <div class="font-medium text-steel-800">Email</div>
                  <div class="text-steel-500">info@ggn-gear.com</div>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                <div>
                  <div class="font-medium text-steel-800">Phone</div>
                  <div class="text-steel-500">+86-577-xxxxxxxx</div>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <div>
                  <div class="font-medium text-steel-800">Address</div>
                  <div class="text-steel-500">Zhejiang Province, China</div>
                </div>
              </li>
            </ul>
          </div>

          <div class="bg-steel-50 rounded-xl p-6">
            <h3 class="font-bold text-steel-900 mb-3">Business Hours</h3>
            <ul class="space-y-2 text-sm text-steel-500">
              <li class="flex justify-between"><span>Monday – Friday</span><span>8:00 – 18:00</span></li>
              <li class="flex justify-between"><span>Saturday</span><span>9:00 – 16:00</span></li>
              <li class="flex justify-between"><span>Sunday</span><span>Closed</span></li>
            </ul>
            <p class="mt-3 text-xs text-steel-400">All times in China Standard Time (UTC+8)</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
